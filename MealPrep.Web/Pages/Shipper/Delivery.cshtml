@page
@model MealPrep.Web.Pages.Shipper.DeliveryModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Giao Hàng Hôm Nay";
}

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900">🚚 Giao Hàng</h1>
        <p class="text-gray-600 mt-1 text-sm">@DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</p>
    </div>
    <span id="orderCountBadge" class="glass px-5 py-2.5 rounded-xl text-sm font-medium text-gray-900">
        <i class="bi bi-box-seam me-1.5 text-emerald-600"></i>
        <span id="orderCount">@Model.TodaysOrders.Count</span> đơn hàng
    </span>
</div>

@Html.AntiForgeryToken()

<div id="emptyState" class="@(Model.TodaysOrders.Count > 0 ? "hidden" : "")">
    <div class="glass rounded-2xl p-16 text-center">
        <div class="text-6xl mb-5 opacity-80">📦</div>
        <h3 class="text-xl font-bold mb-2 text-gray-800">Chưa có đơn hàng</h3>
        <p class="text-gray-600">Bạn chưa được gán đơn giao hàng nào. Đơn mới sẽ xuất hiện tự động khi Admin phân công.</p>
    </div>
</div>
<div id="orderList" class="space-y-5 @(Model.TodaysOrders.Count == 0 ? "hidden" : "")">
        @foreach (var order in Model.TodaysOrders)
        {
            var allDelivered = order.Items.All(i => i.IsDelivered);
            <div class="glass rounded-2xl p-6 border border-gray-200 hover:border-gray-300 transition" id="order-@order.OrderId">
                <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                    <div>
                        <h3 class="font-bold text-lg text-gray-900">Đơn #@order.OrderId — @order.CustomerName</h3>
                        <p class="text-sm text-gray-600 mt-0.5"><i class="bi bi-clock me-1.5"></i> @order.DeliverySlotName</p>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                        @{
                            var statusColor = order.Status switch {
                                BusinessObjects.Enums.OrderStatus.Delivered => "bg-emerald-100 text-emerald-700",
                                BusinessObjects.Enums.OrderStatus.ConfirmedByUser => "bg-purple-100 text-purple-700",
                                BusinessObjects.Enums.OrderStatus.InProgress or BusinessObjects.Enums.OrderStatus.Delivering => "bg-amber-100 text-amber-700",
                                BusinessObjects.Enums.OrderStatus.Cancelled => "bg-red-100 text-red-700",
                                _ => "bg-gray-100 text-gray-700"
                            };
                        }
                        <span class="order-status-text text-xs px-2 py-0.5 rounded @statusColor font-semibold">@order.Status</span>
                        <form method="post" asp-page-handler="UpdateOrderStatus" class="inline-flex items-center gap-1" onsubmit="return submitOrderStatus(this, event)">
                            <input type="hidden" name="orderId" value="@order.OrderId" />
                            <select name="newStatus" class="px-2 py-1 bg-white border border-gray-300 rounded text-xs text-gray-900">
                                @foreach (var st in new[] { BusinessObjects.Enums.OrderStatus.Planned, BusinessObjects.Enums.OrderStatus.Preparing, BusinessObjects.Enums.OrderStatus.Delivering, BusinessObjects.Enums.OrderStatus.Delivered })
                                {
                                    <option value="@((int)st)" selected="@(st == order.Status)">@st</option>
                                }
                            </select>
                            <button type="submit" class="px-2 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded">OK</button>
                        </form>
                        <a href="/Shipper/OrderDetail?id=@order.OrderId" class="px-3 py-1.5 text-xs text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-lg transition">Xem chi tiết</a>
                        @if (allDelivered && order.Status != BusinessObjects.Enums.OrderStatus.Delivered && order.Status != BusinessObjects.Enums.OrderStatus.ConfirmedByUser)
                        {
                            <button onclick="completeOrder(@order.OrderId)"
                                    class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded-lg transition"
                                    id="complete-@order.OrderId">
                                ✅ Hoàn thành
                            </button>
                        }
                    </div>
                </div>

                <div class="space-y-3">
                    @foreach (var item in order.Items)
                    {
                        <div class="flex items-center gap-4 p-4 rounded-xl bg-gray-50 border border-gray-200" id="item-@item.OrderItemId">
                            @if (item.MealImageUrls?.Length > 0)
                            {
                                <img src="@item.MealImageUrls[0]" alt="@item.MealName"
                                     class="w-14 h-14 object-cover rounded-lg flex-shrink-0" />
                            }
                            else
                            {
                                <div class="w-14 h-14 rounded-lg bg-gray-200 flex items-center justify-center text-xl flex-shrink-0">🍽️</div>
                            }
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">@item.DeliverySlotName</span>
                                    <span class="text-xs text-gray-500">@item.Status</span>
                                </div>
                                <p class="font-medium text-sm truncate text-gray-900 mt-1">@item.MealName</p>
                                <p class="text-xs text-gray-600 truncate">@item.DeliveryAddress</p>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0 flex-wrap justify-end">
                                <form method="post" asp-page-handler="UpdateOrderItemStatus" class="inline-flex items-center gap-1" onsubmit="return submitItemStatus(this, event)">
                                    <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                    <select name="newStatus" class="px-2 py-1 bg-white border border-gray-300 rounded text-xs text-gray-900">
                                        @foreach (BusinessObjects.Enums.OrderItemStatus st in Enum.GetValues<BusinessObjects.Enums.OrderItemStatus>())
                                        {
                                            <option value="@((int)st)" selected="@(st == item.Status)">@st</option>
                                        }
                                    </select>
                                    <button type="submit" class="px-2 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded">OK</button>
                                </form>
                                <div class="item-proof-area flex items-center gap-2">
                                    @if (item.IsDelivered)
                                    {
                                        <span class="text-emerald-600 text-xs font-semibold">
                                            <i class="bi bi-check-circle-fill"></i> Đã giao
                                        </span>
                                        @if (item.ProofImageUrls?.Length > 0)
                                        {
                                            @foreach (var url in item.ProofImageUrls)
                                            {
                                                <img src="@url" alt="Proof" class="w-8 h-8 rounded object-cover border border-gray-200 cursor-pointer" onclick="showLightbox(this.src)" />
                                            }
                                        }
                                        <button onclick="openCamera(@item.OrderItemId)" class="text-xs text-emerald-600 hover:text-emerald-700">+ Thêm ảnh</button>
                                    }
                                    else
                                    {
                                        <button onclick="openCamera(@item.OrderItemId)"
                                                class="px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white text-xs rounded-lg transition">
                                            <i class="bi bi-camera"></i> Chụp ảnh
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
</div>

<!-- Hidden file input (multiple) for camera/upload -->
<input type="file" id="photoInput" accept="image/*" capture="environment" multiple class="hidden" />

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4" onclick="this.classList.add('hidden')">
    <img id="lightboxImg" class="max-w-full max-h-full rounded-xl" />
</div>

<!-- Camera FAB -->
<button onclick="document.getElementById('photoInput').click()"
        class="fixed bottom-6 right-6 w-14 h-14 bg-emerald-600 hover:bg-emerald-700 text-white rounded-full shadow-lg flex items-center justify-center text-xl transition z-40 lg:hidden">
    <i class="bi bi-camera-fill"></i>
</button>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        let currentItemId = null;

        async function submitOrderStatus(form, e) {
            e.preventDefault();
            const fd = new FormData(form);
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) fd.append('__RequestVerificationToken', token);
            try {
                const r = await fetch('?handler=UpdateOrderStatus', { method: 'POST', body: fd, headers: { 'RequestVerificationToken': token ?? '' } });
                const d = await r.json();
                if (d.success) showToast('Đã cập nhật trạng thái'); else showToast(d.error || 'Lỗi', 'error');
            } catch { showToast('Lỗi', 'error'); }
            return false;
        }
        async function submitItemStatus(form, e) {
            e.preventDefault();
            const fd = new FormData(form);
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) fd.append('__RequestVerificationToken', token);
            const orderItemId = parseInt(form.querySelector('input[name="orderItemId"]').value, 10);
            const newStatus = form.querySelector('select[name="newStatus"]').value;
            try {
                const r = await fetch('?handler=UpdateOrderItemStatus', { method: 'POST', body: fd, headers: { 'RequestVerificationToken': token ?? '' } });
                const d = await r.json();
                if (d.success) {
                    showToast('Đã cập nhật trạng thái món');
                    const itemEl = document.getElementById(`item-${orderItemId}`);
                    const statusSpan = itemEl?.querySelector('.text-gray-500');
                    if (statusSpan) statusSpan.textContent = ['','Planned','Preparing','Delivering','Delivered','Cancelled'][parseInt(newStatus,10)] || newStatus;
                } else showToast(d.error || 'Lỗi', 'error');
            } catch { showToast('Lỗi', 'error'); }
            return false;
        }

        function openCamera(orderItemId) {
            currentItemId = orderItemId;
            document.getElementById('photoInput').click();
        }

        document.getElementById('photoInput').addEventListener('change', async function () {
            if (!this.files?.length || !currentItemId) return;
            for (let i = 0; i < this.files.length; i++) {
                await uploadProof(currentItemId, this.files[i]);
            }
            this.value = '';
            currentItemId = null;
        });

        async function uploadProof(orderItemId, file) {
            const formData = new FormData();
            formData.append('orderItemId', orderItemId);
            formData.append('photo', file);
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

            const itemEl = document.getElementById(`item-${orderItemId}`);
            const proofArea = itemEl?.querySelector('.item-proof-area');
            const camBtn = proofArea?.querySelector('button[onclick^="openCamera"]');
            if (camBtn) { camBtn.disabled = true; camBtn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-gray-300 border-t-emerald-600 rounded-full animate-spin"></span>'; }

            try {
                const res = await fetch('?handler=UploadProof', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Đã tải ảnh xác nhận giao hàng!');
                    const proofArea = itemEl?.querySelector('.item-proof-area');
                    if (proofArea) {
                        const existingImgs = proofArea.querySelectorAll('img[alt="Proof"]');
                        const hasDelivered = proofArea.querySelector('.text-emerald-600, .text-emerald-400');
                        const newImg = `<img src="${data.proofUrl}" alt="Proof" class="w-8 h-8 rounded object-cover border border-gray-200 cursor-pointer" onclick="showLightbox(this.src)" />`;
                        if (hasDelivered && existingImgs.length > 0) {
                            existingImgs[existingImgs.length - 1].insertAdjacentHTML('afterend', newImg);
                        } else {
                            proofArea.innerHTML = `<span class="text-emerald-600 text-xs font-semibold"><i class="bi bi-check-circle-fill"></i> Đã giao</span>${newImg}<button onclick="openCamera(${orderItemId})" class="text-xs text-emerald-600 hover:text-emerald-700">+ Thêm ảnh</button>`;
                        }
                    }
                } else {
                    showToast(data.error || 'Lỗi tải ảnh.', 'error');
                }
            } catch {
                showToast('Lỗi kết nối.', 'error');
            }
            if (camBtn) { camBtn.disabled = false; const isDelivered = proofArea?.querySelector('.text-emerald-600, .text-emerald-400'); camBtn.innerHTML = isDelivered ? '+ Thêm ảnh' : '<i class="bi bi-camera"></i> Chụp ảnh'; }
        }

        async function completeOrder(orderId) {
            const btn = document.getElementById(`complete-${orderId}`);
            btn.disabled = true;
            btn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-gray-300 border-t-emerald-600 rounded-full animate-spin"></span>';
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

            try {
                const res = await fetch(`?handler=CompleteOrder&orderId=${orderId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                const data = await res.json();
                if (data.success) {
                    showToast(`Đơn #${orderId} đã hoàn thành!`);
                    const card = document.getElementById(`order-${orderId}`);
                    if (card) {
                        const statusSpan = card.querySelector('.text-xs.font-semibold');
                        if (statusSpan) { statusSpan.textContent = 'Hoàn thành'; statusSpan.className = 'order-status-text text-xs px-2 py-0.5 rounded bg-emerald-100 text-emerald-700 font-semibold'; }
                        const completeBtn = document.getElementById(`complete-${orderId}`);
                        if (completeBtn) completeBtn.remove();
                    }
                } else {
                    showToast('Có lỗi xảy ra.', 'error');
                }
            } catch {
                showToast('Lỗi kết nối.', 'error');
            }
        }

        function showLightbox(src) {
            event.stopPropagation();
            document.getElementById('lightboxImg').src = src;
            document.getElementById('lightbox').classList.remove('hidden');
        }

        // SignalR — OrderHub (assignments) + OrderTrackingHub (delivery tracking)
        const userId = '@(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier) ?? "")'.toLowerCase();
        const orderConn = new signalR.HubConnectionBuilder().withUrl('/hubs/order').withAutomaticReconnect().build();
        const trackConn = new signalR.HubConnectionBuilder().withUrl('/hubs/order-tracking').withAutomaticReconnect().build();

        orderConn.on('ReceiveNewAssignment', async (orderId) => {
            showToast('📦 Bạn có đơn giao hàng mới!');
            const r = await fetch(`?handler=OrderJson&orderId=${orderId}`);
            const data = await r.json();
            if (data.found && data.order) {
                document.getElementById('emptyState')?.classList.add('hidden');
                document.getElementById('orderList')?.classList.remove('hidden');
                if (!document.getElementById(`order-${orderId}`)) {
                    const card = renderOrderCard(data.order);
                    document.getElementById('orderList')?.insertAdjacentHTML('afterbegin', card);
                }
                const cnt = document.getElementById('orderCount');
                if (cnt) cnt.textContent = document.querySelectorAll('#orderList [id^="order-"]').length;
            }
        });
        orderConn.on('ReceiveOrderStatusUpdate', (orderId, status) => {
            const card = document.getElementById(`order-${orderId}`);
            if (!card) return;
            const statusSpan = card.querySelector('.order-status-text');
            if (statusSpan) {
                const label = status === 'ConfirmedByUser' ? 'Đã xác nhận' : (status === 'Delivered' ? 'Delivered' : status);
                statusSpan.textContent = label;
                statusSpan.className = 'order-status-text text-xs px-2 py-0.5 rounded font-semibold ' + statusColor(status);
            }
        });

        function statusColor(s) {
            const t = String(s||'');
            if (t.includes('ConfirmedByUser')) return 'bg-purple-100 text-purple-700';
            if (t.includes('Delivered')) return 'bg-emerald-100 text-emerald-700';
            if (t.includes('Disputed')) return 'bg-orange-100 text-orange-700';
            if (t.includes('Delivering') || t.includes('InProgress')) return 'bg-amber-100 text-amber-700';
            if (t.includes('Cancelled')) return 'bg-red-100 text-red-700';
            return 'bg-gray-100 text-gray-700';
        }
        function renderOrderCard(o) {
            const allDelivered = o.items.every(i => i.isDelivered);
            const completeBtn = allDelivered && o.status !== 'Delivered' && o.status !== 'ConfirmedByUser'
                ? `<button onclick="completeOrder(${o.orderId})" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded-lg transition" id="complete-${o.orderId}">✅ Hoàn thành</button>`
                : '';
            const itemsHtml = (o.items || []).map(item => {
                const slotName = (item.deliverySlotName || '—').replace(/</g,'&lt;');
                const proofUrls = (item.proofImageUrls || []).map(url => `<img src="${url}" alt="Proof" class="w-8 h-8 rounded object-cover border border-gray-200 cursor-pointer" onclick="showLightbox(this.src)" />`).join('');
                const proofHtml = item.isDelivered
                    ? `<span class="text-emerald-600 text-xs font-semibold"><i class="bi bi-check-circle-fill"></i> Đã giao</span>${proofUrls}<button onclick="openCamera(${item.orderItemId})" class="text-xs text-emerald-600 hover:text-emerald-700">+ Thêm ảnh</button>`
                    : `<button onclick="openCamera(${item.orderItemId})" class="px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white text-xs rounded-lg transition"><i class="bi bi-camera"></i> Chụp ảnh</button>`;
                const img = (item.mealImageUrls?.length > 0) ? `<img src="${item.mealImageUrls[0]}" alt="${(item.mealName||'').replace(/"/g,'&quot;')}" class="w-14 h-14 object-cover rounded-lg flex-shrink-0" />` : '<div class="w-14 h-14 rounded-lg bg-gray-200 flex items-center justify-center text-xl flex-shrink-0">🍽️</div>';
                const statusOpts = [1,2,3,4,5].map(v => `<option value="${v}" ${(item.status===v||item.status===v.toString())?'selected':''}>${['','Planned','Preparing','Delivering','Delivered','Cancelled'][v]}</option>`).join('');
                return `<div class="flex items-center gap-4 p-4 rounded-xl bg-gray-50 border border-gray-200" id="item-${item.orderItemId}">${img}<div class="flex-1 min-w-0"><div class="flex items-center gap-2 flex-wrap"><span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">${slotName}</span><span class="text-xs text-gray-500">${item.status||''}</span></div><p class="font-medium text-sm truncate text-gray-900 mt-1">${(item.mealName||'').replace(/</g,'&lt;')}</p><p class="text-xs text-gray-600 truncate">${(item.deliveryAddress||'').replace(/</g,'&lt;')}</p></div><div class="flex items-center gap-2 flex-shrink-0 flex-wrap justify-end"><form method="post" action="?handler=UpdateOrderItemStatus" class="inline-flex items-center gap-1" onsubmit="return submitItemStatus(this, event)"><input type="hidden" name="orderItemId" value="${item.orderItemId}" /><select name="newStatus" class="px-2 py-1 bg-white border border-gray-300 rounded text-xs text-gray-900">${statusOpts}</select><button type="submit" class="px-2 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded">OK</button></form><div class="item-proof-area flex items-center gap-2">${proofHtml}</div></div></div>`;
            }).join('');
            const statusOpts = [0,1,2,3].map(v => `<option value="${v}" ${o.status === v ? 'selected' : ''}>${['Planned','Preparing','Delivering','Delivered'][v]}</option>`).join('');
            const statusText = typeof o.status === 'number' ? ['Planned','Preparing','Delivering','Delivered'][o.status] || o.status : o.status;
            return `<div class="glass rounded-2xl p-6 border border-gray-200" id="order-${o.orderId}"><div class="flex flex-wrap items-center justify-between gap-3 mb-4"><div><h3 class="font-bold text-lg text-gray-900">Đơn #${o.orderId} — ${(o.customerName||'').replace(/</g,'&lt;')}</h3><p class="text-xs text-gray-600 mt-0.5"><i class="bi bi-clock me-1.5"></i> ${(o.deliverySlotName||'').replace(/</g,'&lt;')}</p></div><div class="flex items-center gap-2 flex-wrap"><span class="order-status-text text-xs px-2 py-0.5 rounded ${statusColor(statusText)} font-semibold">${statusText}</span><form method="post" action="?handler=UpdateOrderStatus" class="inline-flex items-center gap-1" onsubmit="return submitOrderStatus(this, event)"><input type="hidden" name="orderId" value="${o.orderId}" /><select name="newStatus" class="px-2 py-1 bg-white border border-gray-300 rounded text-xs text-gray-900">${statusOpts}</select><button type="submit" class="px-2 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-xs rounded">OK</button></form><a href="/Shipper/OrderDetail?id=${o.orderId}" class="px-3 py-1.5 text-xs text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50 rounded-lg">Xem chi tiết</a>${completeBtn}</div></div><div class="space-y-3">${itemsHtml}</div></div>`;
        }

        trackConn.on('OrderItemStatusChanged', (orderItemId, orderId, status, proofUrl) => {
            const itemEl = document.getElementById(`item-${orderItemId}`);
            if (!itemEl) return;
            const statusSpan = itemEl.querySelector('.flex.items-center.gap-2 .text-gray-500');
            if (statusSpan) statusSpan.textContent = status || '';
            if (status === 'Delivered' && proofUrl) {
                const proofArea = itemEl.querySelector('.item-proof-area');
                if (proofArea) proofArea.innerHTML = `<span class="text-emerald-600 text-xs font-semibold"><i class="bi bi-check-circle-fill"></i> Đã giao</span><img src="${proofUrl}" alt="Proof" class="w-8 h-8 rounded object-cover border border-gray-200 cursor-pointer" onclick="showLightbox(this.src)" /><button onclick="openCamera(${orderItemId})" class="text-xs text-emerald-600 hover:text-emerald-700">+ Thêm ảnh</button>`;
            }
        });
        trackConn.on('OrderStatusChanged', (orderId, status, source) => {
            const card = document.getElementById(`order-${orderId}`);
            if (!card) return;
            const statusSpan = card.querySelector('.order-status-text');
            if (statusSpan) {
                const label = status === 'ConfirmedByUser' ? 'Đã xác nhận' : (status === 'Delivered' ? 'Delivered' : status);
                statusSpan.textContent = label;
                statusSpan.className = 'order-status-text text-xs px-2 py-0.5 rounded font-semibold ' + statusColor(status);
            }
            const completeBtn = document.getElementById(`complete-${orderId}`);
            if (completeBtn) completeBtn.remove();
        });

        const joinShipperGroups = () => {
            if (!userId) { console.warn('Shipper userId not found'); return; }
            orderConn.invoke('JoinShipperGroup', userId).catch(console.warn);
            trackConn.invoke('JoinShipperGroup', userId).catch(console.warn);
        };
        orderConn.start().then(joinShipperGroups).catch(e => { console.error('OrderHub:', e); showToast('Lỗi kết nối realtime', 'error'); });
        trackConn.start().then(joinShipperGroups).catch(console.error);
        orderConn.onreconnected(joinShipperGroups);
        trackConn.onreconnected(joinShipperGroups);
    </script>
}
