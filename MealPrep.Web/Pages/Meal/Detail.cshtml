@page
@model MealPrep.Web.Pages.Meal.DetailModel
@{
    Layout = "_DarkLayout";
    ViewData["Title"] = Model.Meal?.Name ?? "Chi Tiết Món Ăn";
}

@if (Model.Meal == null)
{
    <div class="glass rounded-2xl p-12 text-center">
        <div class="text-5xl mb-4">😕</div>
        <h3 class="text-lg font-bold mb-2">Không tìm thấy</h3>
        <p class="text-gray-400 text-sm mb-4">Món ăn này không tồn tại hoặc đã bị xóa.</p>
        <a href="/Meal" class="inline-block px-6 py-2.5 bg-emerald-500 text-white text-sm font-semibold rounded-xl">← Quay lại</a>
    </div>
}
else
{
    var meal = Model.Meal;

    <!-- Back button -->
    <a href="/Meal" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-emerald-400 transition mb-6">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Image Gallery -->
        <div>
            @if (meal.Images?.Any() == true)
            {
                <div class="rounded-2xl overflow-hidden mb-4">
                    <img id="mainImage" src="@meal.Images[0]" alt="@meal.Name"
                         class="w-full h-80 object-cover" />
                </div>
                @if (meal.Images.Length > 1)
                {
                    <div class="flex gap-2">
                        @foreach (var img in meal.Images)
                        {
                            <button onclick="document.getElementById('mainImage').src='@img'"
                                    class="w-16 h-16 rounded-xl overflow-hidden border-2 border-transparent hover:border-emerald-500 transition flex-shrink-0">
                                <img src="@img" alt="" class="w-full h-full object-cover" />
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="rounded-2xl bg-white/5 h-80 flex items-center justify-center text-6xl">🍽️</div>
            }
        </div>

        <!-- Details -->
        <div>
            <h1 class="text-3xl font-bold mb-2">@meal.Name</h1>

            <div id="meal-rating-block" class="flex items-center gap-2 mb-4" data-meal-id="@meal.Id" style="@(meal.AvgRating > 0 ? "" : "display:none")">
                <div id="meal-stars" class="flex gap-0.5 text-yellow-400">
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="bi @(i < Math.Round(meal.AvgRating ?? 0) ? "bi-star-fill" : "bi-star") text-sm"></i>
                    }
                </div>
                <span id="meal-avg-value" class="text-sm text-gray-400">@((meal.AvgRating ?? 0).ToString("0.0"))</span>
            </div>

            @if (!string.IsNullOrEmpty(meal.Description))
            {
                <p class="text-gray-400 leading-relaxed mb-6">@meal.Description</p>
            }

            <!-- Nutrition -->
            <div class="glass rounded-2xl p-5 mb-6">
                <h2 class="font-bold text-sm mb-4 text-gray-300 uppercase tracking-wider">Thành Phần Dinh Dưỡng</h2>
                <div class="grid grid-cols-2 gap-4">
                    <div class="text-center p-3 rounded-xl bg-white/[0.04]">
                        <i class="bi bi-fire text-orange-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1">@meal.Calories</p>
                        <p class="text-xs text-gray-500">Calo (kcal)</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-white/[0.04]">
                        <i class="bi bi-droplet text-blue-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1">@(meal.Protein)g</p>
                        <p class="text-xs text-gray-500">Protein</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-white/[0.04]">
                        <i class="bi bi-lightning text-yellow-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1">@(meal.Carbs)g</p>
                        <p class="text-xs text-gray-500">Carbs</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-white/[0.04]">
                        <i class="bi bi-circle-fill text-pink-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1">@(meal.Fat)g</p>
                        <p class="text-xs text-gray-500">Chất Béo</p>
                    </div>
                </div>
            </div>

            <!-- Ingredients -->
            @if (meal.Ingredients?.Any() == true)
            {
                <div class="glass rounded-2xl p-5">
                    <h2 class="font-bold text-sm mb-3 text-gray-300 uppercase tracking-wider">Nguyên Liệu</h2>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var ing in meal.Ingredients)
                        {
                            <span class="px-3 py-1.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                                @ing
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @section Scripts {
        <script>
            (function() {
                const mealId = @meal.Id;
                const mealConn = new signalR.HubConnectionBuilder().withUrl('/hubs/meal').withAutomaticReconnect().build();
                mealConn.on('ReceiveNewRating', function(data) {
                    if (!data || data.mealId !== mealId) return;
                    const block = document.getElementById('meal-rating-block');
                    const avgEl = document.getElementById('meal-avg-value');
                    const starsEl = document.getElementById('meal-stars');
                    if (block && avgEl && starsEl) {
                        block.style.display = '';
                        var avg = data.newAvgRating ?? 0;
                        avgEl.textContent = avg.toFixed(1);
                        var rounded = Math.round(avg);
                        starsEl.querySelectorAll('i').forEach(function(star, i) {
                            star.className = 'bi ' + (i < rounded ? 'bi-star-fill' : 'bi-star') + ' text-sm';
                        });
                    }
                });

                mealConn.on('MealDeleted', function(deletedId) {
                    if (deletedId === mealId) {
                        if (typeof showToast === 'function') showToast('Món ăn này đã bị xóa', 'error');
                        window.location.href = '/Meal';
                    }
                });

                mealConn.on('MealUpdated', function(meal) {
                    if (!meal || meal.id !== mealId) return;
                    const h1 = document.querySelector('h1');
                    if (h1) h1.textContent = meal.name || '';
                    const descEl = document.querySelector('.leading-relaxed');
                    if (descEl) descEl.textContent = meal.description || '';
                    const mainImg = document.getElementById('mainImage');
                    if (mainImg && meal.images && meal.images[0]) mainImg.src = meal.images[0];
                    else if (mainImg && meal.thumbnailUrl) mainImg.src = meal.thumbnailUrl;
                    const nutritionDivs = document.querySelectorAll('.glass.rounded-2xl .grid .text-center');
                    if (nutritionDivs.length >= 4) {
                        nutritionDivs[0].querySelector('p.font-bold').textContent = meal.calories || 0;
                        nutritionDivs[1].querySelector('p.font-bold').textContent = (meal.protein || 0) + 'g';
                        nutritionDivs[2].querySelector('p.font-bold').textContent = (meal.carbs || 0) + 'g';
                        nutritionDivs[3].querySelector('p.font-bold').textContent = (meal.fat || 0) + 'g';
                    }
                    const ingredientsWrap = document.querySelector('.glass.rounded-2xl .flex.flex-wrap.gap-2');
                    if (ingredientsWrap && meal.ingredients && meal.ingredients.length) {
                        ingredientsWrap.innerHTML = meal.ingredients.map(function(ing) {
                            return '<span class="px-3 py-1.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">' + String(ing).replace(/</g,'&lt;') + '</span>';
                        }).join('');
                    }
                    if (typeof showToast === 'function') showToast('🍽️ Món ăn đã được cập nhật');
                });

                mealConn.start().catch(console.warn);
            })();
        </script>
    }
}
