@page
@model MealPrep.Web.Pages.Meal.DetailModel
@{
    Layout = "_DarkLayout";
    ViewData["Title"] = Model.Meal?.Name ?? "Chi Tiết Món Ăn";
}

@if (Model.Meal == null)
{
    <div class="glass rounded-2xl p-12 text-center">
        <div class="text-5xl mb-4">😕</div>
        <h3 class="text-lg font-bold mb-2">Không tìm thấy</h3>
        <p class="text-slate-600 text-sm mb-4">Món ăn này không tồn tại hoặc đã bị xóa.</p>
        <a href="/Meal" class="inline-block px-6 py-2.5 bg-emerald-500 text-white text-sm font-semibold rounded-xl">← Quay lại</a>
    </div>
}
else
{
    var meal = Model.Meal;

    <!-- Back button -->
    <a href="/Meal" class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-emerald-600 transition mb-6 font-medium">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Image Gallery -->
        <div>
            @if (meal.Images?.Any() == true)
            {
                <div class="rounded-2xl overflow-hidden mb-4">
                    <img id="mainImage" src="@meal.Images[0]" alt="@meal.Name"
                         class="w-full h-80 object-cover" />
                </div>
                @if (meal.Images.Length > 1)
                {
                    <div class="flex gap-2">
                        @foreach (var img in meal.Images)
                        {
                            <button onclick="document.getElementById('mainImage').src='@img'"
                                    class="w-16 h-16 rounded-xl overflow-hidden border-2 border-transparent hover:border-emerald-500 transition flex-shrink-0">
                                <img src="@img" alt="" class="w-full h-full object-cover" />
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="rounded-2xl bg-slate-100 h-80 flex items-center justify-center text-6xl border border-slate-200">🍽️</div>
            }
        </div>

        <!-- Details -->
        <div>
            <h1 class="text-3xl font-bold mb-2 text-slate-900">@meal.Name</h1>

            <div id="meal-rating-block" class="flex items-center gap-2 mb-4" data-meal-id="@meal.Id" style="@(Model.AverageStars > 0 ? "" : "display:none")">
                <div id="meal-stars" class="flex gap-0.5 text-yellow-400">
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="bi @(i < Math.Round(Model.AverageStars) ? "bi-star-fill" : "bi-star") text-sm"></i>
                    }
                </div>
                <span id="meal-avg-value" class="text-sm text-slate-700 font-semibold">@(Model.AverageStars.ToString("0.0"))</span>
                <span class="text-xs text-slate-600">(@Model.TotalReviews đánh giá)</span>
            </div>

            @if (!string.IsNullOrEmpty(meal.Description))
            {
                <p class="text-slate-700 leading-relaxed mb-6">@meal.Description</p>
            }

            <!-- Nutrition -->
            <div class="rounded-2xl p-5 mb-6 bg-white border border-slate-200 shadow-sm">
                <h2 class="font-bold text-sm mb-4 text-slate-700 uppercase tracking-wider">Thành Phần Dinh Dưỡng</h2>
                <div class="grid grid-cols-2 gap-4">
                    <div class="text-center p-3 rounded-xl bg-amber-50 border border-amber-100">
                        <i class="bi bi-fire text-orange-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1 text-slate-900">@meal.Calories</p>
                        <p class="text-xs text-slate-600">Calo (kcal)</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-blue-50 border border-blue-100">
                        <i class="bi bi-droplet text-blue-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1 text-slate-900">@(meal.Protein)g</p>
                        <p class="text-xs text-slate-600">Protein</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-yellow-50 border border-yellow-100">
                        <i class="bi bi-lightning text-yellow-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1 text-slate-900">@(meal.Carbs)g</p>
                        <p class="text-xs text-slate-600">Carbs</p>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-rose-50 border border-rose-100">
                        <i class="bi bi-circle-fill text-pink-400 text-xl"></i>
                        <p class="text-xl font-bold mt-1 text-slate-900">@(meal.Fat)g</p>
                        <p class="text-xs text-slate-600">Chất Béo</p>
                    </div>
                </div>
            </div>

            <!-- Ingredients -->
            @if (Model.IngredientDetails.Any())
            {
                <div class="rounded-2xl p-5 bg-white border border-slate-200 shadow-sm">
                    <h2 class="font-bold text-sm mb-3 text-slate-700 uppercase tracking-wider">Chi Tiết Nguyên Liệu</h2>
                    <div id="ingredient-details-list" class="space-y-2">
                        @foreach (var ing in Model.IngredientDetails)
                        {
                            <div class="flex items-center justify-between rounded-xl bg-slate-50 border border-slate-200 px-3 py-2">
                                <span class="text-sm text-slate-800 font-medium">@ing.Name</span>
                                @if (ing.QuantityInGrams.HasValue)
                                {
                                    <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2 py-1 rounded-full">@ing.QuantityInGrams.Value.ToString("0.##")g</span>
                                }
                                else
                                {
                                    <span class="text-xs font-semibold text-slate-500">@ing.QuantityText</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="review-section" class="mt-8 rounded-2xl p-5 bg-white border border-slate-200 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-bold text-sm text-slate-700 uppercase tracking-wider">Đánh Giá Món Ăn</h2>
            <span class="text-xs text-slate-600">
                @Model.TotalReviews đánh giá
                @if (Model.TotalReviews > 0)
                {
                    <text> • Trang @Model.ReviewPage/@Model.TotalReviewPages</text>
                }
            </span>
        </div>

        @if (Model.Reviews.Any())
        {
            <div class="space-y-3">
                @foreach (var review in Model.Reviews)
                {
                    <div class="rounded-xl bg-slate-50 border border-slate-200 p-4">
                        <div class="flex items-center justify-between gap-3 mb-2">
                            <div class="font-semibold text-sm text-slate-800">@review.UserName</div>
                            <div class="text-xs text-slate-500">@review.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        <div class="flex items-center gap-1 text-yellow-400 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= review.Stars ? "bi-star-fill" : "bi-star") text-xs"></i>
                            }
                            <span class="text-xs text-slate-600 ms-1 font-medium">@review.Stars/5</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(review.Comments))
                        {
                            <p class="text-sm text-slate-700 leading-relaxed mb-2">@review.Comments</p>
                        }

                        @if (review.Tags.Any())
                        {
                            <div class="flex flex-wrap gap-2">
                                @foreach (var tag in review.Tags)
                                {
                                    <span class="px-2 py-1 rounded-full text-[11px] bg-emerald-50 text-emerald-700 border border-emerald-200 font-medium">@tag</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @if (Model.TotalReviewPages > 1)
            {
                <div class="mt-4 flex items-center justify-between gap-3 border-t border-slate-200 pt-4">
                    <a asp-page="/Meal/Detail"
                       asp-route-id="@meal.Id"
                       asp-route-reviewPage="@(Model.ReviewPage - 1)"
                       asp-fragment="review-section"
                       class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-100 @(Model.ReviewPage <= 1 ? "pointer-events-none opacity-50" : "")">
                        <i class="bi bi-chevron-left"></i> Trang trước
                    </a>

                    <div class="text-xs text-slate-600">Hiển thị tối đa @Model.ReviewPageSize đánh giá mỗi trang</div>

                    <a asp-page="/Meal/Detail"
                       asp-route-id="@meal.Id"
                       asp-route-reviewPage="@(Model.ReviewPage + 1)"
                       asp-fragment="review-section"
                       class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-100 @(Model.ReviewPage >= Model.TotalReviewPages ? "pointer-events-none opacity-50" : "")">
                        Trang sau <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="rounded-xl bg-slate-50 border border-slate-200 p-4 text-sm text-slate-600">
                Chưa có đánh giá nào cho món này.
            </div>
        }
    </div>

    @section Scripts {
        <script>
            (function() {
                const mealId = @meal.Id;
                const mealConn = new signalR.HubConnectionBuilder().withUrl('/hubs/meal').withAutomaticReconnect().build();
                mealConn.on('ReceiveNewRating', function(data) {
                    if (!data || data.mealId !== mealId) return;
                    const block = document.getElementById('meal-rating-block');
                    const avgEl = document.getElementById('meal-avg-value');
                    const starsEl = document.getElementById('meal-stars');
                    if (block && avgEl && starsEl) {
                        block.style.display = '';
                        var avg = data.newAvgRating ?? 0;
                        avgEl.textContent = avg.toFixed(1);
                        var rounded = Math.round(avg);
                        starsEl.querySelectorAll('i').forEach(function(star, i) {
                            star.className = 'bi ' + (i < rounded ? 'bi-star-fill' : 'bi-star') + ' text-sm';
                        });
                    }
                });

                mealConn.on('MealDeleted', function(deletedId) {
                    if (deletedId === mealId) {
                        if (typeof showToast === 'function') showToast('Món ăn này đã bị xóa', 'error');
                        window.location.href = '/Meal';
                    }
                });

                mealConn.on('MealUpdated', function(meal) {
                    if (!meal || meal.id !== mealId) return;
                    const h1 = document.querySelector('h1');
                    if (h1) h1.textContent = meal.name || '';
                    const descEl = document.querySelector('.leading-relaxed');
                    if (descEl) descEl.textContent = meal.description || '';
                    const mainImg = document.getElementById('mainImage');
                    if (mainImg && meal.images && meal.images[0]) mainImg.src = meal.images[0];
                    else if (mainImg && meal.thumbnailUrl) mainImg.src = meal.thumbnailUrl;
                    const nutritionDivs = document.querySelectorAll('.glass.rounded-2xl .grid .text-center');
                    if (nutritionDivs.length >= 4) {
                        nutritionDivs[0].querySelector('p.font-bold').textContent = meal.calories || 0;
                        nutritionDivs[1].querySelector('p.font-bold').textContent = (meal.protein || 0) + 'g';
                        nutritionDivs[2].querySelector('p.font-bold').textContent = (meal.carbs || 0) + 'g';
                        nutritionDivs[3].querySelector('p.font-bold').textContent = (meal.fat || 0) + 'g';
                    }
                    const ingredientsWrap = document.getElementById('ingredient-details-list');
                    if (ingredientsWrap && meal.ingredients && meal.ingredients.length) {
                        ingredientsWrap.innerHTML = meal.ingredients.map(function(ing) {
                            return '<div class="flex items-center justify-between rounded-xl bg-slate-50 border border-slate-200 px-3 py-2"><span class="text-sm text-slate-800 font-medium">' + String(ing).replace(/</g,'&lt;') + '</span><span class="text-xs font-semibold text-slate-500">Cập nhật lại để tính gram</span></div>';
                        }).join('');
                    }
                    if (typeof showToast === 'function') showToast('🍽️ Món ăn đã được cập nhật');
                });

                mealConn.start().catch(console.warn);
            })();
        </script>
    }
}
