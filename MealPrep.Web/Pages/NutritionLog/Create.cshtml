@page
@model MealPrep.Web.Pages.NutritionLog.CreateModel
@{
    ViewData["Title"] = "Thêm Nhật Ký Dinh Dưỡng";
}

<div class="max-w-xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
        <a href="/NutritionLog" class="p-2 rounded-xl hover:bg-gray-100 transition">
            <i class="bi bi-arrow-left text-lg"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Thêm Vào Nhật Ký</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-red-600 text-sm flex items-center gap-2">
            <i class="bi bi-exclamation-circle-fill"></i>@Model.ErrorMessage
        </div>
    }

    <div class="glass rounded-2xl p-6">
        <form method="post" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Món Ăn</label>
                <select asp-for="MealId" class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition">
                    <option value="0">-- Chọn món ăn --</option>
                    @foreach (var m in Model.Meals)
                    {
                        <option value="@m.Id">@m.Name (@m.Calories.ToString("N0") cal)</option>
                    }
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Ngày</label>
                    <input type="date" asp-for="Date"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Số Lượng</label>
                    <input type="number" asp-for="Quantity" min="1" max="10"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition" />
                </div>
            </div>

            <button type="submit" class="w-full py-3 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200 flex items-center justify-center gap-2">
                <i class="bi bi-plus-lg"></i>Thêm Vào Nhật Ký
            </button>
        </form>
    </div>
</div>
