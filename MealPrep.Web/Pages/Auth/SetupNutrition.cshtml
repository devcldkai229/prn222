@page
@model MealPrep.Web.Pages.Auth.SetupNutritionModel
@{
    ViewData["Title"] = "Thiết Lập Dinh Dưỡng";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MealPrep</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gradient-to-br from-emerald-50 via-white to-teal-50 min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-lg">
        <!-- Progress -->
        <div class="flex items-center justify-center gap-3 mb-8">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-emerald-600 text-white flex items-center justify-center text-sm font-bold">
                    <i class="bi bi-check-lg"></i>
                </div>
                <span class="text-sm text-emerald-600">Thông Tin</span>
            </div>
            <div class="w-12 h-0.5 bg-emerald-400"></div>
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-emerald-600 text-white flex items-center justify-center text-sm font-bold">2</div>
                <span class="text-sm font-medium text-emerald-700">Dinh Dưỡng</span>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            <div class="text-center mb-8">
                <div class="w-16 h-16 rounded-2xl bg-blue-100 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-heart-pulse text-3xl text-blue-600"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Hồ Sơ Dinh Dưỡng</h1>
                <p class="text-sm text-gray-500 mt-1">Thông tin này giúp AI gợi ý thực đơn phù hợp</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-6 text-red-600 text-sm">
                    <i class="bi bi-exclamation-circle me-1"></i>@Model.ErrorMessage
                </div>
            }

            <form method="post" class="space-y-5">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Chiều Cao (cm)</label>
                        <input type="number" asp-for="Input.HeightCm" placeholder="170"
                               class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition" />
                        <span asp-validation-for="Input.HeightCm" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Cân Nặng (kg)</label>
                        <input type="number" asp-for="Input.WeightKg" step="0.1" placeholder="65"
                               class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition" />
                        <span asp-validation-for="Input.WeightKg" class="text-xs text-red-500"></span>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Mục Tiêu</label>
                    <select asp-for="Input.Goal" asp-items="Html.GetEnumSelectList<BusinessObjects.Enums.FitnessGoal>()"
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Mức Hoạt Động</label>
                    <select asp-for="Input.ActivityLevel" asp-items="Html.GetEnumSelectList<BusinessObjects.Enums.ActivityLevel>()"
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Chế Độ Ăn</label>
                    <select asp-for="Input.DietPreference" asp-items="Html.GetEnumSelectList<BusinessObjects.Enums.DietPreference>()"
                            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Lượng Calo/Ngày (tùy chọn)</label>
                    <input type="number" asp-for="Input.CaloriesInDay" placeholder="2000"
                           class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition" />
                    <span asp-validation-for="Input.CaloriesInDay" class="text-xs text-red-500"></span>
                </div>

                <button type="submit" class="w-full py-3.5 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200 flex items-center justify-center gap-2">
                    <i class="bi bi-check-lg"></i> Hoàn Tất
                </button>

                <a href="/Dashboard" class="block text-center text-sm text-gray-400 hover:text-gray-600 transition mt-2">
                    Bỏ qua, thiết lập sau
                </a>
            </form>
        </div>
    </div>

</body>
</html>
