@page
@model MealPrep.Web.Pages.Auth.RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng Ký — MealPrep";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f0fdf4 0%, #f8fafc 60%, #ecfdf5 100%); }
        .card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.07); }
        .input-field { background: #f8fafc; border: 1px solid #e2e8f0; color: #1e293b; border-radius: 12px; padding: 12px 44px 12px 16px; width: 100%; font-size: 14px; font-family: inherit; outline: none; transition: border-color .2s, box-shadow .2s; }
        .input-field:focus { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,.12); background: #fff; }
        .input-field::placeholder { color: #94a3b8; }
        .btn-otp { padding: 12px 16px; background: #ecfdf5; border: 1px solid #a7f3d0; color: #059669; border-radius: 12px; font-size: 13px; font-weight: 600; font-family: inherit; cursor: pointer; white-space: nowrap; transition: .2s; }
        .btn-otp:hover { background: #d1fae5; }
        .btn-otp:disabled { opacity:.5; cursor:not-allowed; }
        @@keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
        .fade-up { animation: fadeUp .5s cubic-bezier(.34,1.56,.64,1) both; }
        .step-dot { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; transition:.3s; }
        .step-dot.active { background: linear-gradient(135deg,#10b981,#059669); color:white; box-shadow:0 4px 12px rgba(16,185,129,.3); }
        .step-dot.done { background: #d1fae5; color:#059669; }
        .step-dot.pending { background: #f1f5f9; color:#94a3b8; border: 1px solid #e2e8f0; }
        .toast-light { position:fixed; bottom:24px; right:24px; min-width:280px; padding:14px 18px; border-radius:14px; display:flex; align-items:center; gap:10px; font-size:14px; font-weight:500; z-index:9999; transform:translateY(100px); opacity:0; transition:.4s cubic-bezier(.34,1.56,.64,1); background:#fff; border:1px solid #e2e8f0; box-shadow:0 8px 30px rgba(0,0,0,0.1); }
        .toast-light.show { transform:translateY(0); opacity:1; }
        .toast-light.success { border-color:#a7f3d0; color:#059669; }
        .toast-light.error { border-color:#fecaca; color:#dc2626; }
    </style>
</head>
<body class="min-h-screen flex">

    <!-- LEFT decorative panel -->
    <div class="hidden lg:flex flex-col justify-end p-14 relative w-[400px] flex-shrink-0 overflow-hidden bg-gradient-to-br from-emerald-600 to-emerald-800">
        <div class="absolute inset-0" style="background:url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800&q=80') center/cover; opacity:.15;"></div>
        <div class="relative z-10 space-y-5">
            <div class="flex items-center gap-3 mb-8">
                <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center backdrop-blur-sm">
                    <i class="bi bi-leaf-fill text-white text-lg"></i>
                </div>
                <span class="text-2xl font-bold text-white">MealPrep</span>
            </div>
            <h2 class="text-3xl font-extrabold text-white leading-tight">
                Ăn Thông Minh.<br><span class="text-emerald-200">Sống Khỏe Hơn.</span>
            </h2>
            <p class="text-emerald-100 text-sm leading-relaxed">Thực đơn AI cá nhân hóa theo mục tiêu của bạn, giao tươi mỗi ngày.</p>
            <div class="space-y-3 pt-2">
                @foreach (var f in new[] { ("bi-cpu", "Thực đơn AI theo mục tiêu"), ("bi-truck", "Giao hàng tận nơi mỗi ngày"), ("bi-bar-chart-line", "Theo dõi dinh dưỡng"), ("bi-shield-check", "An toàn, đầu bếp chuyên nghiệp") })
                {
                    <div class="flex items-center gap-3 text-sm text-white/90">
                        <div class="w-7 h-7 rounded-lg bg-white/15 flex items-center justify-center flex-shrink-0">
                            <i class="bi @f.Item1 text-white text-xs"></i>
                        </div>
                        @f.Item2
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT form panel -->
    <div class="flex-1 flex flex-col justify-center items-center p-6 lg:p-12 overflow-y-auto">
        <div class="w-full max-w-md fade-up">

            <!-- Mobile logo -->
            <div class="flex lg:hidden items-center justify-center gap-3 mb-6">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center">
                    <i class="bi bi-leaf-fill text-white"></i>
                </div>
                <span class="text-xl font-bold text-gray-900">MealPrep</span>
            </div>

            <!-- Step indicator -->
            <div class="flex items-center mb-6 gap-2">
                <div class="step-dot active" id="step1dot">1</div>
                <div class="flex-1 h-px bg-gray-200" id="stepLine"></div>
                <div class="step-dot pending" id="step2dot">2</div>
                <div class="flex-1 justify-between flex">
                    <span class="text-xs text-gray-400 ml-0">Email</span>
                    <span class="text-xs text-gray-400 mr-0">Hoàn tất</span>
                </div>
            </div>

            <div class="card p-7">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="flex items-center gap-2 p-3 rounded-xl bg-red-50 border border-red-200 text-red-600 text-sm mb-5">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i> @Model.ErrorMessage
                    </div>
                }

                <!-- STEP 1 -->
                <div id="formStep1">
                    <h1 class="text-xl font-bold text-gray-900 mb-1">Tạo tài khoản 🌱</h1>
                    <p class="text-gray-500 text-sm mb-5">Bắt đầu với địa chỉ email của bạn</p>
                    <div class="mb-4">
                        <label class="block text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">Email</label>
                        <div class="relative">
                            <input type="email" id="emailInput" placeholder="ban@example.com" autocomplete="email" class="input-field" />
                            <i class="bi bi-envelope absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                        </div>
                    </div>
                    <button type="button" onclick="goToStep2()"
                            class="w-full py-3 bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-400 hover:to-emerald-500 text-white font-bold rounded-xl transition hover:shadow-lg hover:shadow-emerald-200 text-base">
                        Tiếp tục <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>

                <!-- STEP 2 -->
                <div id="formStep2" style="display:none;">
                    <h1 class="text-xl font-bold text-gray-900 mb-1">Hoàn tất hồ sơ ✨</h1>
                    <p class="text-gray-500 text-sm mb-5">Vài thông tin nữa để bắt đầu</p>

                    <form method="post" asp-page-handler="Register">
                        @Html.AntiForgeryToken()
                        <input asp-for="Input.Email" type="hidden" id="hiddenEmail" />

                        <div class="mb-3">
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5 uppercase tracking-wide">Họ và tên</label>
                            <input asp-for="Input.FullName" type="text" placeholder="Nguyễn Văn A" autocomplete="name" class="input-field" />
                            <span asp-validation-for="Input.FullName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5 uppercase tracking-wide">Mật khẩu</label>
                            <div class="relative">
                                <input asp-for="Input.Password" type="password" placeholder="Ít nhất 6 ký tự" id="regPwd" autocomplete="new-password" class="input-field" />
                                <button type="button" onclick="toggleRegPwd()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
                                    <i class="bi bi-eye" id="regPwdIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5 uppercase tracking-wide">Xác nhận mật khẩu</label>
                            <input asp-for="Input.ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" class="input-field" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="mb-4">
                            <label class="block text-xs font-semibold text-gray-500 mb-1.5 uppercase tracking-wide">Mã xác thực OTP</label>
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <input asp-for="Input.OtpCode" type="text" placeholder="6 chữ số" maxlength="6" inputmode="numeric" pattern="\d{6}" class="input-field" />
                                </div>
                                <button type="button" id="sendOtpBtn" onclick="sendOtp()" class="btn-otp flex-shrink-0">
                                    <i class="bi bi-send me-1"></i>Gửi OTP
                                </button>
                            </div>
                            <span asp-validation-for="Input.OtpCode" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <button type="submit"
                                class="w-full py-3 bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-400 hover:to-emerald-500 text-white font-bold rounded-xl transition hover:shadow-lg hover:shadow-emerald-200 text-base">
                            <i class="bi bi-person-check me-1"></i>Tạo Tài Khoản
                        </button>
                    </form>
                </div>
            </div>

            <p class="text-center text-sm text-gray-500 mt-5">
                Đã có tài khoản?
                <a asp-page="/Auth/Login" class="text-emerald-600 font-semibold hover:text-emerald-700 transition ml-1">Đăng nhập</a>
            </p>
        </div>
    </div>

    <div class="toast-light" id="toast">
        <i class="bi" id="toastIcon"></i>
        <span id="toastMsg"></span>
    </div>

    <script>
        function showToast(message, type = 'success') {
            const t = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            t.className = 'toast-light ' + type;
            icon.className = 'bi ' + (type === 'success' ? 'bi-check-circle-fill' : 'bi-x-circle-fill');
            document.getElementById('toastMsg').textContent = message;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 4000);
        }

        function goToStep2() {
            const email = document.getElementById('emailInput').value.trim();
            if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                showToast('Vui lòng nhập email hợp lệ.', 'error'); return;
            }
            document.getElementById('hiddenEmail').value = email;
            document.getElementById('formStep1').style.display = 'none';
            document.getElementById('formStep2').style.display = 'block';
            document.getElementById('step1dot').className = 'step-dot done';
            document.getElementById('step1dot').innerHTML = '<i class="bi bi-check" style="font-size:12px;"></i>';
            document.getElementById('step2dot').className = 'step-dot active';
            document.getElementById('stepLine').style.background = '#a7f3d0';
        }

        function toggleRegPwd() {
            const i = document.getElementById('regPwd');
            const icon = document.getElementById('regPwdIcon');
            if (i.type === 'password') { i.type = 'text'; icon.className = 'bi bi-eye-slash'; }
            else { i.type = 'password'; icon.className = 'bi bi-eye'; }
        }

        async function sendOtp() {
            const email = document.getElementById('hiddenEmail').value;
            const btn = document.getElementById('sendOtpBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-arrow-repeat me-1"></i>Đang gửi...';
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            try {
                const resp = await fetch('?handler=SendOtp', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: new URLSearchParams({ 'Input.Email': email, '__RequestVerificationToken': token })
                });
                const data = await resp.json();
                showToast(data.message, data.success ? 'success' : 'error');
                if (data.success) {
                    if (data.devOtp) {
                        const inp = document.querySelector('input[name="Input.OtpCode"]');
                        if (inp) inp.value = data.devOtp;
                        showToast('[DEV] OTP: ' + data.devOtp, 'success');
                    }
                    let count = 60;
                    const timer = setInterval(() => {
                        count--;
                        btn.innerHTML = '<i class="bi bi-clock me-1"></i>Gửi lại (' + count + 's)';
                        if (count <= 0) { clearInterval(timer); btn.disabled = false; btn.innerHTML = '<i class="bi bi-send me-1"></i>Gửi lại OTP'; }
                    }, 1000);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send me-1"></i>Gửi OTP';
                }
            } catch {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send me-1"></i>Gửi OTP';
                showToast('Lỗi kết nối. Vui lòng thử lại.', 'error');
            }
        }
    </script>
</body>
</html>
