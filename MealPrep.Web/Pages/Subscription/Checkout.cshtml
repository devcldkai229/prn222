@page
@model MealPrep.Web.Pages.Subscription.CheckoutModel
@{
    Layout = "_DarkLayout";
    ViewData["Title"] = "Đăng Ký Gói";
}

<!-- Step indicator -->
<div class="max-w-2xl mx-auto mb-8">
    <div class="flex items-center gap-2">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-gray-400 text-sm font-bold">
                <i class="bi bi-check text-emerald-400 text-xs"></i>
            </div>
            <span class="text-sm text-gray-500">Chọn Gói</span>
        </div>
        <div class="flex-1 h-px bg-emerald-500/30 mx-2"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center text-white text-sm font-bold">2</div>
            <span class="text-sm font-semibold text-white">Cấu Hình</span>
        </div>
        <div class="flex-1 h-px bg-white/10 mx-2"></div>
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-gray-500 text-sm font-bold">3</div>
            <span class="text-sm text-gray-500">Thanh Toán</span>
        </div>
    </div>
</div>

<div class="max-w-2xl mx-auto">
    <div class="text-center mb-6">
        <h1 class="text-2xl font-bold">📋 Cấu Hình Đăng Ký</h1>
        <p class="text-gray-400 mt-1">Cài đặt chi tiết cho gói của bạn trước khi thanh toán.</p>
    </div>

    @if (Model.SelectedPlan == null)
    {
        <div class="glass rounded-2xl p-12 text-center">
            <div class="text-5xl mb-4">⚠️</div>
            <h3 class="text-xl font-bold mb-2">Gói không hợp lệ</h3>
            <p class="text-gray-400 mb-4">Không tìm thấy gói dịch vụ. Vui lòng chọn lại.</p>
            <a href="/Subscription/Plans" class="inline-block px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl font-semibold transition">
                Xem Gói Dịch Vụ
            </a>
        </div>
    }
    else
    {
        <div class="grid md:grid-cols-5 gap-5">
            <!-- LEFT: Config form -->
            <div class="md:col-span-3">
                <form method="post" asp-page-handler="Checkout" class="glass rounded-2xl p-6 space-y-5">
                    <input type="hidden" asp-for="PlanId" />
                    <input type="hidden" asp-for="MealsPerDay" value="@Model.SelectedPlan.MealsPerDay" />
                    <input type="hidden" asp-for="DeliveryTimeSlot" value="Morning" />

                    <!-- Start date -->
                    <div>
                        <h3 class="text-sm font-semibold text-gray-300 mb-2 flex items-center gap-2">
                            <i class="bi bi-calendar-event text-emerald-400"></i> Ngày Bắt Đầu
                        </h3>
                        <input type="date" asp-for="StartDate"
                               min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                               onchange="updateEndDate()"
                               class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none text-sm" />
                        <span asp-validation-for="StartDate" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <!-- End date (read-only) -->
                    <div>
                        <h3 class="text-sm font-semibold text-gray-300 mb-2 flex items-center gap-2">
                            <i class="bi bi-calendar-check text-gray-500"></i> Ngày Kết Thúc
                            <span class="text-xs text-gray-600">(tự động)</span>
                        </h3>
                        <div id="endDateDisplay"
                             class="w-full px-4 py-3 bg-white/[0.02] border border-white/5 rounded-xl text-gray-500 text-sm cursor-not-allowed">
                            —
                        </div>
                    </div>

                    <!-- Note -->
                    <div class="p-3 rounded-xl bg-blue-500/5 border border-blue-500/15 text-xs text-blue-300 flex items-start gap-2">
                        <i class="bi bi-info-circle-fill flex-shrink-0 mt-0.5"></i>
                        Sau khi đăng ký, hệ thống sẽ tự động tạo các đơn giao hàng hàng ngày. Bạn có thể chọn thực đơn trong phần <strong>Thực Đơn Tuần</strong>.
                    </div>

                    <button type="submit" id="payBtn"
                            class="w-full py-3.5 bg-gradient-to-r from-pink-500 to-rose-500 hover:from-pink-400 hover:to-rose-400 text-white rounded-xl font-bold text-base transition transform hover:scale-[1.01] hover:shadow-lg hover:shadow-pink-500/20 flex items-center justify-center gap-2">
                        <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.png" class="w-6 h-6 rounded" alt="Momo" onerror="this.style.display='none'" />
                        Thanh Toán Qua Momo
                    </button>

                    <a href="/Subscription/Plans" class="block text-center text-sm text-gray-500 hover:text-gray-300 transition">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại chọn gói
                    </a>
                </form>
            </div>

            <!-- RIGHT: Order summary -->
            <div class="md:col-span-2">
                <div class="glass rounded-2xl p-5 sticky top-6">
                    <h3 class="font-bold mb-4 text-sm text-gray-400 uppercase tracking-wide">Tóm Tắt Đơn Hàng</h3>

                    <div class="flex items-start gap-3 mb-5 pb-5 border-b border-white/5">
                        <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
                            <i class="bi bi-bag-heart-fill text-emerald-400"></i>
                        </div>
                        <div>
                            <p class="font-semibold text-white text-sm">@Model.SelectedPlan.Name</p>
                            <p class="text-xs text-gray-500 mt-0.5">@Model.SelectedPlan.DurationDays ngày</p>
                        </div>
                    </div>

                    <div class="space-y-2.5 text-sm mb-5 pb-5 border-b border-white/5">
                        <div class="flex justify-between">
                            <span class="text-gray-400">Giá cơ bản</span>
                            <span class="text-white font-medium">@Model.SelectedPlan.BasePrice.ToString("N0")₫</span>
                        </div>
                        <div class="flex justify-between" id="extraRow" style="display:none!important;">
                            <span class="text-gray-400">Phụ thu thêm bữa</span>
                            <span class="text-blue-300 font-medium" id="extraCost">+0₫</span>
                        </div>
                        <div class="flex justify-between text-xs text-gray-600">
                            <span>Giao hàng</span>
                            <span class="text-emerald-400">Miễn phí</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-center mb-5">
                        <span class="font-bold text-white">Tổng cộng</span>
                        <span class="text-2xl font-extrabold text-emerald-400" id="totalPrice">@Model.SelectedPlan.BasePrice.ToString("N0")₫</span>
                    </div>

                    <div class="space-y-2 text-xs text-gray-500">
                        <div class="flex items-center gap-2"><i class="bi bi-shield-check text-emerald-400"></i> Thanh toán bảo mật qua Momo</div>
                        <div class="flex items-center gap-2"><i class="bi bi-arrow-repeat text-emerald-400"></i> Hủy gói bất cứ lúc nào</div>
                        <div class="flex items-center gap-2"><i class="bi bi-truck text-emerald-400"></i> Giao tận nơi, miễn phí</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @if (Model.SelectedPlan != null)
    {
        <script>
            const durationDays = @Model.SelectedPlan.DurationDays;
            const basePrice = @Model.SelectedPlan.BasePrice;
            document.getElementById('totalPrice').textContent = basePrice.toLocaleString('vi-VN') + '₫';

            function updateEndDate() {
                const start = document.querySelector('input[name="StartDate"]').value;
                if (!start) { document.getElementById('endDateDisplay').textContent = '—'; return; }
                const d = new Date(start);
                d.setDate(d.getDate() + durationDays - 1);
                document.getElementById('endDateDisplay').textContent = d.toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric' });
            }

            updateEndDate();
        </script>
    }
}
