@page
@model MealPrep.Web.Pages.Subscription.PaymentReturnModel
@{
    Layout = "_DarkLayout";
    ViewData["Title"] = Model.IsSuccess ? "Thanh Toán Thành Công" : "Thanh Toán Thất Bại";
}

<div class="flex items-center justify-center min-h-[60vh]">
    <div class="glass rounded-2xl p-10 max-w-md w-full text-center">
        @if (Model.IsSuccess)
        {
            <div class="w-20 h-20 rounded-full bg-emerald-500/10 flex items-center justify-center mx-auto mb-6">
                <i class="bi bi-check-circle-fill text-emerald-400 text-4xl"></i>
            </div>
            <h1 class="text-2xl font-bold mb-2 text-emerald-400">Thanh Toán Thành Công!</h1>
            <p class="text-gray-400 mb-6">@Model.StatusMessage</p>
            <a href="@Model.RedirectAfterPaymentUrl" class="inline-block px-8 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl font-semibold transition">
                <i class="bi bi-box-seam me-1"></i> Xem Gói Đăng Ký
            </a>
        }
        else
        {
            <div class="w-20 h-20 rounded-full bg-red-500/10 flex items-center justify-center mx-auto mb-6">
                <i class="bi bi-x-circle-fill text-red-400 text-4xl"></i>
            </div>
            <h1 class="text-2xl font-bold mb-2 text-red-400">Thanh Toán Thất Bại</h1>
            <p class="text-gray-400 mb-6">@Model.StatusMessage</p>
            <div class="flex gap-3 justify-center">
                <a href="/Subscription/Plans" class="px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl font-semibold transition">
                    Xem Gói Dịch Vụ
                </a>
                <a href="/Subscription/MySubscriptions" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl font-semibold transition">
                    Gói Của Tôi
                </a>
            </div>
        }
    </div>
</div>
