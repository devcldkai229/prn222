@page
@model MealPrep.Web.Pages.Feedback.MySummaryModel
@{
    ViewData["Title"] = "Thống Kê Đánh Giá";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Thống Kê Đánh Giá Của Tôi</h1>
        <a href="/Feedback" class="px-4 py-2 bg-emerald-600 text-white rounded-xl text-sm font-medium hover:bg-emerald-700 transition">
            <i class="bi bi-star me-1"></i>Đánh Giá Món Ăn
        </a>
    </div>

    @if (Model.Summary.TotalRatings == 0)
    {
        <div class="glass rounded-2xl p-12 text-center">
            <i class="bi bi-star text-5xl text-gray-300"></i>
            <p class="mt-4 text-gray-500">Bạn chưa đánh giá món ăn nào.</p>
        </div>
    }
    else
    {
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="glass rounded-2xl p-6 text-center">
                <p class="text-4xl font-bold text-emerald-600">@Model.Summary.TotalRatings</p>
                <p class="text-sm text-gray-500 mt-1">Tổng đánh giá</p>
            </div>
            <div class="glass rounded-2xl p-6 text-center">
                <p class="text-4xl font-bold text-amber-500">@Model.Summary.AverageStars.ToString("F1")</p>
                <p class="text-sm text-gray-500 mt-1">Điểm trung bình</p>
            </div>
            <div class="glass rounded-2xl p-6 text-center">
                <div class="flex justify-center gap-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Math.Round(Model.Summary.AverageStars) ? "bi-star-fill text-amber-400" : "bi-star text-gray-300") text-2xl"></i>
                    }
                </div>
                <p class="text-sm text-gray-500 mt-2">Đánh giá trung bình</p>
            </div>
        </div>

        <!-- Star Distribution -->
        <div class="glass rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Phân Bố Số Sao</h3>
            <div class="space-y-3">
                @for (int star = 5; star >= 1; star--)
                {
                    var count = Model.Summary.StarDistribution.GetValueOrDefault(star, 0);
                    var pct = Model.Summary.TotalRatings > 0 ? (double)count / Model.Summary.TotalRatings * 100 : 0;
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-medium text-gray-600 w-12">@star <i class="bi bi-star-fill text-amber-400 text-xs"></i></span>
                        <div class="flex-1 bg-gray-100 rounded-full h-3 overflow-hidden">
                            <div class="bg-amber-400 h-full rounded-full transition-all" style="width: @pct%"></div>
                        </div>
                        <span class="text-sm text-gray-500 w-16 text-right">@count (@pct.ToString("F0")%)</span>
                    </div>
                }
            </div>
        </div>

        <!-- Top/Lowest Rated -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="glass rounded-2xl p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4"><i class="bi bi-hand-thumbs-up text-emerald-500 me-2"></i>Món Yêu Thích</h3>
                <div class="space-y-3">
                    @foreach (var meal in Model.Summary.TopRatedMeals)
                    {
                        <div class="flex items-center justify-between bg-slate-50 rounded-xl px-4 py-3">
                            <span class="text-sm font-medium text-gray-900">@meal.MealName</span>
                            <div class="flex items-center gap-1">
                                <i class="bi bi-star-fill text-amber-400 text-xs"></i>
                                <span class="text-sm font-semibold text-gray-700">@meal.AverageStars.ToString("F1")</span>
                                <span class="text-xs text-gray-400">(@meal.RatingCount)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="glass rounded-2xl p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4"><i class="bi bi-hand-thumbs-down text-red-500 me-2"></i>Món Đánh Giá Thấp</h3>
                <div class="space-y-3">
                    @foreach (var meal in Model.Summary.LowestRatedMeals)
                    {
                        <div class="flex items-center justify-between bg-slate-50 rounded-xl px-4 py-3">
                            <span class="text-sm font-medium text-gray-900">@meal.MealName</span>
                            <div class="flex items-center gap-1">
                                <i class="bi bi-star-fill text-amber-400 text-xs"></i>
                                <span class="text-sm font-semibold text-gray-700">@meal.AverageStars.ToString("F1")</span>
                                <span class="text-xs text-gray-400">(@meal.RatingCount)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
