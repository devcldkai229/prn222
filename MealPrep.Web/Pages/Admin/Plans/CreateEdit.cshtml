@page
@model MealPrep.Web.Pages.Admin.Plans.CreateEditModel
@using MealPrep.BLL.Services
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.IsEdit ? "Sửa Gói Dịch Vụ" : "Thêm Gói Dịch Vụ";
}

<div class="flex items-center gap-3 mb-6">
    <a href="/Admin/Plans" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-white/10 flex items-center justify-center transition">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="text-2xl font-bold">@(Model.IsEdit ? "✏️ Sửa Gói Dịch Vụ" : "➕ Thêm Gói Dịch Vụ")</h1>
</div>

<form method="post" class="max-w-2xl">
    <input type="hidden" asp-for="PlanId" />

    <div class="glass rounded-2xl p-6 space-y-5 mb-6">
        <!-- Name -->
        <div>
            <label class="block text-xs text-gray-500 mb-1">Tên gói *</label>
            <input asp-for="Dto.Name" type="text" required
                   class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none" />
            <span asp-validation-for="Dto.Name" class="text-red-400 text-xs"></span>
        </div>

        <!-- Description -->
        <div>
            <label class="block text-xs text-gray-500 mb-1">Mô tả</label>
            <textarea asp-for="Dto.Description" rows="3"
                      class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none resize-none"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <!-- Duration -->
            <div>
                <label class="block text-xs text-gray-500 mb-1">Thời hạn (ngày) *</label>
                <input asp-for="Dto.DurationDays" type="number" min="1" required
                       class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none" />
            </div>
            <!-- Meals/Day -->
            <div>
                <label class="block text-xs text-gray-500 mb-1">Bữa/ngày *</label>
                <input asp-for="Dto.MealsPerDay" type="number" min="1" max="3" required
                       class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none" />
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <!-- Base Price -->
            <div>
                <label class="block text-xs text-gray-500 mb-1">Giá cơ bản (₫) *</label>
                <input asp-for="Dto.BasePrice" type="number" min="0" step="1000" required
                       class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none" />
            </div>
            <!-- Extra Price -->
            <div>
                <label class="block text-xs text-gray-500 mb-1">Giá thêm (₫) *</label>
                <input asp-for="Dto.ExtraPrice" type="number" min="0" step="1000" required
                       class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white focus:border-emerald-500 focus:outline-none" />
            </div>
        </div>

        <!-- IsActive -->
        <div class="flex items-center gap-3">
            <input asp-for="Dto.IsActive" type="checkbox" class="w-5 h-5 rounded bg-white/5 border-white/10 text-emerald-500 focus:ring-emerald-500" />
            <label class="text-sm">Hoạt động</label>
        </div>
    </div>

    <div class="flex gap-3">
        <button type="submit" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl font-semibold transition">
            <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Cập Nhật" : "Tạo Gói")
        </button>
        <a href="/Admin/Plans" class="px-6 py-3 bg-white/5 hover:bg-white/10 rounded-xl transition">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
