@page
@model MealPrep.Web.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";

    var d = Model.Dashboard;
    var mode = (Model.Mode ?? "overview").Trim().ToLowerInvariant();
    var showOperations = mode is "overview" or "operations";
    var showStrategic = mode is "overview" or "strategic";
    var hasCustomRange = d.IsCustomRange;
    var fromValue = d.RangeStartDate.ToString("yyyy-MM-dd");
    var toValue = d.RangeEndDate.ToString("yyyy-MM-dd");

    var revenueDelta = d.YesterdaysRevenue > 0
        ? ((d.TodaysRevenue - d.YesterdaysRevenue) / d.YesterdaysRevenue * 100m)
        : 0m;

    string ModeClass(string key)
        => mode == key
            ? "bg-emerald-600 text-white shadow-md shadow-emerald-600/20 border border-emerald-700"
            : "bg-slate-100 text-slate-800 border border-slate-300 hover:bg-slate-200";

    string FormatMetric(decimal value, string format)
        => format switch
        {
            "currency" => value.ToString("N0") + " VND",
            "percent" => value.ToString("0.0") + "%",
            _ => value.ToString("N0"),
        };

    var comparisonQuery = $"&q1y={d.SelectedQuarter1Year}&q1={d.SelectedQuarter1}&q2y={d.SelectedQuarter2Year}&q2={d.SelectedQuarter2}&y1={d.SelectedYear1}&y2={d.SelectedYear2}";

    string ComparisonTrendClass(decimal value)
        => value >= 0m ? "text-emerald-600" : "text-red-600";

    string ComparisonPercentText(decimal? value)
        => value.HasValue ? $"{value.Value:+0.0;-0.0}%" : "N/A";

    string ModeHref(string key)
        => hasCustomRange
            ? $"?mode={key}&from={d.RangeStartDate:yyyy-MM-dd}&to={d.RangeEndDate:yyyy-MM-dd}{comparisonQuery}"
            : $"?mode={key}&days={d.SelectedDays}{comparisonQuery}";

    string DaysHref(int day)
        => $"?mode={mode}&days={day}{comparisonQuery}";
}

@section Styles {
    <style>
        .dash-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 8px 22px rgba(15, 23, 42, 0.05);
        }

        .hero-band {
            background:
                radial-gradient(circle at 15% 20%, rgba(16, 185, 129, 0.18), transparent 34%),
                radial-gradient(circle at 85% 25%, rgba(59, 130, 246, 0.17), transparent 32%),
                linear-gradient(135deg, #f0fdf4, #eff6ff 60%, #f8fafc);
            border: 1px solid #dbeafe;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 1rem;
            align-items: stretch;
        }

        .hero-copy {
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 100%;
        }

        .hero-controls {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: .75rem;
        }

        .hero-control-card {
            border: 1px solid rgba(255, 255, 255, .95);
            background: rgba(255, 255, 255, .88);
            border-radius: 1rem;
            padding: .625rem;
        }

        .range-form-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: .5rem;
        }

        .range-input {
            width: 100%;
            min-width: 0;
        }

        @@media (min-width: 1024px) {
            .hero-grid {
                grid-template-columns: minmax(0, 1fr) 42rem;
                gap: 1.25rem;
            }

            .range-form-grid {
                grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
                align-items: end;
            }
        }

        .metric-label {
            color: #64748b;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            font-weight: 700;
        }

        .metric-value {
            color: #0f172a;
            font-size: 1.5rem;
            line-height: 1.2;
            font-weight: 800;
        }

        .slot-bar {
            height: 8px;
            border-radius: 9999px;
            background: #e2e8f0;
            overflow: hidden;
        }

        .slot-bar > span {
            display: block;
            height: 100%;
            background: linear-gradient(90deg, #14b8a6, #f59e0b);
        }
    </style>
}

<div class="space-y-6">
    <section class="hero-band rounded-3xl px-6 py-5 lg:px-8 lg:py-6">
        <div class="hero-grid">
            <div class="hero-copy">
                <p class="text-xs font-semibold tracking-[.15em] text-emerald-700 uppercase">Operations Intelligence</p>
                <h1 class="text-2xl lg:text-3xl font-extrabold text-slate-900 mt-1">Admin Dashboard</h1>
                <p class="text-sm text-slate-600 mt-2">Giảm nhiễu thông tin bằng cách chuyển chế độ xem theo nhu cầu vận hành hoặc chiến lược.</p>
            </div>

            <div class="hero-controls">
                <div class="hero-control-card flex flex-wrap items-center gap-2">
                    <a href="@ModeHref("overview")" class="px-3 py-1.5 rounded-xl text-sm font-semibold @ModeClass("overview")">Tổng quan</a>
                    <a href="@ModeHref("operations")" class="px-3 py-1.5 rounded-xl text-sm font-semibold @ModeClass("operations")">Hằng ngày</a>
                    <a href="@ModeHref("strategic")" class="px-3 py-1.5 rounded-xl text-sm font-semibold @ModeClass("strategic")">Dài hạn</a>
                </div>

                @if (showOperations)
                {
                    <form method="get" class="hero-control-card range-form-grid">
                        <input type="hidden" name="mode" value="@mode" />
                        <div>
                            <label for="from-date" class="block text-xs font-semibold text-slate-500 px-1 mb-1">Từ ngày</label>
                            <input id="from-date" type="date" name="from" value="@fromValue" class="range-input px-2.5 py-1.5 rounded-xl text-sm bg-white text-slate-800 border border-slate-300" />
                        </div>
                        <div>
                            <label for="to-date" class="block text-xs font-semibold text-slate-500 px-1 mb-1">Đến ngày</label>
                            <input id="to-date" type="date" name="to" value="@toValue" class="range-input px-2.5 py-1.5 rounded-xl text-sm bg-white text-slate-800 border border-slate-300" />
                        </div>
                        <button type="submit" class="px-4 py-1.5 rounded-xl text-sm font-semibold bg-emerald-600 text-white border border-emerald-700 h-[38px]">Áp dụng</button>
                    </form>

                    <div class="hero-control-card flex flex-wrap items-center gap-2 lg:justify-end">
                        <span class="text-xs font-semibold text-slate-500 px-2 min-w-[96px]">Khung thời gian</span>
                        <a href="@DaysHref(7)" class="px-3 py-1.5 rounded-xl text-sm font-semibold @(!hasCustomRange && d.SelectedDays == 7 ? "bg-emerald-600 text-white border border-emerald-700" : "bg-slate-100 text-slate-800 border border-slate-300")">7 ngày</a>
                        <a href="@DaysHref(30)" class="px-3 py-1.5 rounded-xl text-sm font-semibold @(!hasCustomRange && d.SelectedDays == 30 ? "bg-emerald-600 text-white border border-emerald-700" : "bg-slate-100 text-slate-800 border border-slate-300")">30 ngày</a>
                        <a href="@DaysHref(90)" class="px-3 py-1.5 rounded-xl text-sm font-semibold @(!hasCustomRange && d.SelectedDays == 90 ? "bg-emerald-600 text-white border border-emerald-700" : "bg-slate-100 text-slate-800 border border-slate-300")">90 ngày</a>
                    </div>

                    @if (hasCustomRange)
                    {
                        <p class="text-xs text-slate-600 text-right">Đang lọc theo khoảng: <span class="font-semibold">@d.RangeStartDate.ToString("dd/MM/yyyy") - @d.RangeEndDate.ToString("dd/MM/yyyy")</span></p>
                    }
                }
            </div>
        </div>
    </section>

    <section class="dash-card rounded-2xl p-5">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-bold text-slate-900">Cảnh báo ưu tiên</h2>
            <span class="text-xs text-slate-500">Exception-first</span>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            @foreach (var alert in d.Alerts)
            {
                var tone = alert.Severity == "critical"
                    ? "bg-red-50 border-red-200 text-red-800"
                    : alert.Severity == "warning"
                        ? "bg-amber-50 border-amber-200 text-amber-800"
                        : "bg-blue-50 border-blue-200 text-blue-800";

                <div class="rounded-xl border p-3 @tone">
                    <p class="font-semibold">@alert.Title</p>
                    <p class="text-sm opacity-90">@alert.Detail</p>
                </div>
            }
        </div>
    </section>

    @if (showOperations)
    {
        <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
            <article class="dash-card rounded-2xl p-4">
                <p class="metric-label">Doanh thu hôm nay</p>
                <p class="metric-value mt-1">@d.TodaysRevenue.ToString("N0") VND</p>
                <p class="text-xs mt-2 @(revenueDelta >= 0 ? "text-emerald-600" : "text-red-600")">
                    <i class="bi bi-arrow-@(revenueDelta >= 0 ? "up" : "down")"></i>
                    @Math.Abs(revenueDelta).ToString("0.0")% so với hôm qua
                </p>
            </article>

            <article class="dash-card rounded-2xl p-4">
                <p class="metric-label">Doanh thu @d.SelectedDays ngày</p>
                <p class="metric-value mt-1">@d.RevenueInRange.ToString("N0") VND</p>
                <p class="text-xs text-slate-500 mt-2">Nguồn từ thanh toán Paid</p>
            </article>

            <article class="dash-card rounded-2xl p-4">
                <p class="metric-label">Đơn hàng @d.SelectedDays ngày</p>
                <p class="metric-value mt-1">@d.TotalOrdersInRange</p>
                <p class="text-xs text-slate-500 mt-2">Hoàn tất: @d.DeliveredOrdersInRange | Hủy: @d.CancelledOrdersInRange</p>
            </article>

            <article class="dash-card rounded-2xl p-4">
                <p class="metric-label">Tỉ lệ hoàn tất / thanh toán</p>
                <p class="metric-value mt-1">@d.OrderCompletionRate.ToString("0.0")% / @d.PaymentSuccessRate.ToString("0.0")%</p>
                <p class="text-xs text-slate-500 mt-2">Hiệu suất vận hành trong kỳ</p>
            </article>
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Doanh thu @d.SelectedDays ngày gần nhất</h3>
                <canvas id="revenueChart" height="160"></canvas>
            </article>

            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Phân bố trạng thái đơn</h3>
                <canvas id="orderStatusChart" height="160"></canvas>
            </article>
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <article class="dash-card rounded-2xl p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-base font-bold text-slate-900">Top món bán chạy</h3>
                    <span class="text-xs text-slate-500">Theo số lượng</span>
                </div>
                @if (d.TopSellingMeals.Any())
                {
                    <div class="space-y-2">
                        @foreach (var meal in d.TopSellingMeals)
                        {
                            <div class="flex items-center justify-between rounded-xl border border-slate-100 bg-slate-50 p-2.5">
                                <p class="text-sm text-slate-700">@meal.Name</p>
                                <p class="text-sm font-bold text-emerald-700">@meal.Quantity</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500">Chưa có dữ liệu.</p>
                }
            </article>

            <article class="dash-card rounded-2xl p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-base font-bold text-slate-900">Món bị đánh giá thấp</h3>
                    <span class="text-xs text-slate-500">>= 2 đánh giá</span>
                </div>
                @if (d.LowRatedMeals.Any())
                {
                    <div class="space-y-2">
                        @foreach (var meal in d.LowRatedMeals)
                        {
                            <div class="rounded-xl border border-slate-100 bg-slate-50 p-2.5">
                                <div class="flex items-center justify-between">
                                    <p class="text-sm text-slate-700">@meal.Name</p>
                                    <p class="text-sm font-bold text-amber-700">@meal.AvgStars.ToString("0.0")*</p>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">@meal.RatingCount luot danh gia</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500">Chưa có dữ liệu.</p>
                }
            </article>

            <article class="dash-card rounded-2xl p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-base font-bold text-slate-900">Tải slot giao ngày mai</h3>
                    <span class="text-xs text-slate-500">Used / Capacity</span>
                </div>
                @if (d.DeliverySlotLoadsTomorrow.Any())
                {
                    <div class="space-y-3">
                        @foreach (var slot in d.DeliverySlotLoadsTomorrow)
                        {
                            var ratio = slot.Capacity > 0 ? Math.Min(100m, (decimal)slot.Used * 100m / slot.Capacity) : 0m;
                            <div>
                                <div class="flex items-center justify-between text-sm mb-1">
                                    <p class="font-semibold text-slate-700">@slot.SlotName</p>
                                    <p class="text-slate-500">@slot.Used/@slot.Capacity (@ratio.ToString("0.#")%)</p>
                                </div>
                                <div class="slot-bar">
                                    <span style="width: @ratio.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%"></span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500">Chưa có dữ liệu.</p>
                }
            </article>
        </section>
    }

    @if (showStrategic)
    {
        <section class="dash-card rounded-2xl p-5 space-y-5">
            <div class="flex items-center justify-between">
                <h3 class="text-base font-bold text-slate-900">So sánh doanh thu tùy chọn</h3>
                <span class="text-xs text-slate-500">Chọn quý hoặc năm bất kỳ</span>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
                <article class="rounded-xl border border-slate-200 p-4 bg-slate-50/70">
                    <p class="text-sm font-semibold text-slate-700 mb-3">So sánh giữa 2 quý</p>
                    <form id="quarterCompareForm" method="get" class="grid grid-cols-1 md:grid-cols-2 gap-3" data-compare-form="quarter">
                        <input type="hidden" name="mode" value="@mode" />
                        @if (hasCustomRange)
                        {
                            <input type="hidden" name="from" value="@fromValue" />
                            <input type="hidden" name="to" value="@toValue" />
                        }
                        else
                        {
                            <input type="hidden" name="days" value="@d.SelectedDays" />
                        }
                        <input type="hidden" name="y1" value="@d.SelectedYear1" />
                        <input type="hidden" name="y2" value="@d.SelectedYear2" />

                        <div class="space-y-2">
                            <label class="text-xs font-semibold text-slate-500">Mốc A</label>
                            <div class="grid grid-cols-2 gap-2">
                                <select name="q1y" class="px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="q1ySelect">
                                    @foreach (var year in d.RevenueComparisonYears)
                                    {
                                        if (year == d.SelectedQuarter1Year)
                                        {
                                            <option value="@year" selected>@year</option>
                                        }
                                        else
                                        {
                                            <option value="@year">@year</option>
                                        }
                                    }
                                </select>
                                <select name="q1" class="px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="q1Select">
                                    @for (var q = 1; q <= 4; q++)
                                    {
                                        if (q == d.SelectedQuarter1)
                                        {
                                            <option value="@q" selected>@($"Q{q}")</option>
                                        }
                                        else
                                        {
                                            <option value="@q">@($"Q{q}")</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-semibold text-slate-500">Mốc B</label>
                            <div class="grid grid-cols-2 gap-2">
                                <select name="q2y" class="px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="q2ySelect">
                                    @foreach (var year in d.RevenueComparisonYears)
                                    {
                                        if (year == d.SelectedQuarter2Year)
                                        {
                                            <option value="@year" selected>@year</option>
                                        }
                                        else
                                        {
                                            <option value="@year">@year</option>
                                        }
                                    }
                                </select>
                                <select name="q2" class="px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="q2Select">
                                    @for (var q = 1; q <= 4; q++)
                                    {
                                        if (q == d.SelectedQuarter2)
                                        {
                                            <option value="@q" selected>@($"Q{q}")</option>
                                        }
                                        else
                                        {
                                            <option value="@q">@($"Q{q}")</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="md:col-span-2 flex items-center justify-between gap-3 pt-1">
                            <p class="text-xs text-slate-500" id="quarterCompareSummary">A: <span class="font-semibold">@($"Q{d.SelectedQuarter1}/{d.SelectedQuarter1Year}")</span> | B: <span class="font-semibold">@($"Q{d.SelectedQuarter2}/{d.SelectedQuarter2Year}")</span></p>
                            <button type="submit" class="px-3.5 py-2 rounded-xl text-sm font-semibold bg-emerald-600 text-white border border-emerald-700" id="quarterCompareButton">So sánh quý</button>
                        </div>
                    </form>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mt-3">
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Doanh thu A</p>
                            <p class="font-bold text-slate-800" id="quarterRevenueA">@d.SelectedQuarter1Revenue.ToString("N0") VND</p>
                        </div>
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Doanh thu B</p>
                            <p class="font-bold text-slate-800" id="quarterRevenueB">@d.SelectedQuarter2Revenue.ToString("N0") VND</p>
                        </div>
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Chênh lệch A-B</p>
                            <p class="font-bold @ComparisonTrendClass(d.SelectedQuarterRevenueDiffAmount)" id="quarterDiffAmount">@d.SelectedQuarterRevenueDiffAmount.ToString("+#,##0;-#,##0;0") VND</p>
                            <p class="text-xs @ComparisonTrendClass(d.SelectedQuarterRevenueDiffAmount)" id="quarterDiffPercent">@ComparisonPercentText(d.SelectedQuarterRevenueDiffPercent)</p>
                        </div>
                    </div>
                </article>

                <article class="rounded-xl border border-slate-200 p-4 bg-slate-50/70">
                    <p class="text-sm font-semibold text-slate-700 mb-3">So sánh giữa 2 năm</p>
                    <form id="yearCompareForm" method="get" class="grid grid-cols-1 md:grid-cols-2 gap-3" data-compare-form="year">
                        <input type="hidden" name="mode" value="@mode" />
                        @if (hasCustomRange)
                        {
                            <input type="hidden" name="from" value="@fromValue" />
                            <input type="hidden" name="to" value="@toValue" />
                        }
                        else
                        {
                            <input type="hidden" name="days" value="@d.SelectedDays" />
                        }
                        <input type="hidden" name="q1y" value="@d.SelectedQuarter1Year" />
                        <input type="hidden" name="q1" value="@d.SelectedQuarter1" />
                        <input type="hidden" name="q2y" value="@d.SelectedQuarter2Year" />
                        <input type="hidden" name="q2" value="@d.SelectedQuarter2" />

                        <div class="space-y-2">
                            <label class="text-xs font-semibold text-slate-500">Năm A</label>
                            <select name="y1" class="w-full px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="y1Select">
                                @foreach (var year in d.RevenueComparisonYears)
                                {
                                    if (year == d.SelectedYear1)
                                    {
                                        <option value="@year" selected>@year</option>
                                    }
                                    else
                                    {
                                        <option value="@year">@year</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-semibold text-slate-500">Năm B</label>
                            <select name="y2" class="w-full px-2.5 py-2 rounded-xl bg-white border border-slate-300 text-sm" id="y2Select">
                                @foreach (var year in d.RevenueComparisonYears)
                                {
                                    if (year == d.SelectedYear2)
                                    {
                                        <option value="@year" selected>@year</option>
                                    }
                                    else
                                    {
                                        <option value="@year">@year</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="md:col-span-2 flex items-center justify-between gap-3 pt-1">
                            <p class="text-xs text-slate-500" id="yearCompareSummary">A: <span class="font-semibold">@d.SelectedYear1</span> | B: <span class="font-semibold">@d.SelectedYear2</span></p>
                            <button type="submit" class="px-3.5 py-2 rounded-xl text-sm font-semibold bg-emerald-600 text-white border border-emerald-700" id="yearCompareButton">So sánh năm</button>
                        </div>
                    </form>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mt-3">
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Doanh thu năm A</p>
                            <p class="font-bold text-slate-800" id="yearRevenueA">@d.SelectedYear1Revenue.ToString("N0") VND</p>
                        </div>
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Doanh thu năm B</p>
                            <p class="font-bold text-slate-800" id="yearRevenueB">@d.SelectedYear2Revenue.ToString("N0") VND</p>
                        </div>
                        <div class="rounded-lg bg-white border border-slate-200 p-2.5">
                            <p class="text-xs text-slate-500">Chênh lệch A-B</p>
                            <p class="font-bold @ComparisonTrendClass(d.SelectedYearRevenueDiffAmount)" id="yearDiffAmount">@d.SelectedYearRevenueDiffAmount.ToString("+#,##0;-#,##0;0") VND</p>
                            <p class="text-xs @ComparisonTrendClass(d.SelectedYearRevenueDiffAmount)" id="yearDiffPercent">@ComparisonPercentText(d.SelectedYearRevenueDiffPercent)</p>
                        </div>
                    </div>
                </article>
            </div>
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <article class="dash-card rounded-2xl p-5">
                <p class="metric-label">So sánh quý</p>
                <p class="metric-value mt-1">@d.CurrentQuarterRevenue.ToString("N0") VND</p>
                <p class="text-xs text-slate-500 mt-1">Quý trước: @d.PreviousQuarterRevenue.ToString("N0") VND</p>
                <p class="text-sm mt-3 @((d.QuarterOverQuarterChangePercent >= 0m) ? "text-emerald-600" : "text-red-600") font-semibold">
                    <i class="bi bi-arrow-@((d.QuarterOverQuarterChangePercent >= 0m) ? "up" : "down")"></i>
                    @Math.Abs(d.QuarterOverQuarterChangePercent).ToString("0.0")% QoQ
                </p>
            </article>

            <article class="dash-card rounded-2xl p-5">
                <p class="metric-label">So sánh năm</p>
                <p class="metric-value mt-1">@d.CurrentYearRevenue.ToString("N0") VND</p>
                <p class="text-xs text-slate-500 mt-1">Năm trước: @d.PreviousYearRevenue.ToString("N0") VND</p>
                <p class="text-sm mt-3 @((d.YearOverYearChangePercent >= 0m) ? "text-emerald-600" : "text-red-600") font-semibold">
                    <i class="bi bi-arrow-@((d.YearOverYearChangePercent >= 0m) ? "up" : "down")"></i>
                    @Math.Abs(d.YearOverYearChangePercent).ToString("0.0")% YoY
                </p>
            </article>
        </section>

        <section class="dash-card rounded-2xl p-5">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-base font-bold text-slate-900">Ma trận so sánh đa chỉ số QoQ / YoY</h3>
                <span class="text-xs text-slate-500">Không chỉ doanh thu</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full min-w-[920px] text-sm">
                    <thead>
                        <tr class="text-left border-b border-slate-200 text-slate-500 uppercase text-xs">
                            <th class="py-2 pr-2">Chỉ số</th>
                            <th class="py-2 px-2 text-right">Q hiện tại</th>
                            <th class="py-2 px-2 text-right">Q trước</th>
                            <th class="py-2 px-2 text-right">QoQ</th>
                            <th class="py-2 px-2 text-right">Năm hiện tại</th>
                            <th class="py-2 px-2 text-right">Năm trước</th>
                            <th class="py-2 pl-2 text-right">YoY</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in d.StrategicMetrics)
                        {
                            var rowQoqUp = row.QuarterOverQuarterChangePercent.GetValueOrDefault() >= 0m;
                            var rowYoyUp = row.YearOverYearChangePercent.GetValueOrDefault() >= 0m;
                            <tr class="border-b border-slate-100">
                                <td class="py-2 pr-2 text-slate-700 font-medium">@row.Metric</td>
                                <td class="py-2 px-2 text-right text-slate-700">@FormatMetric(row.CurrentQuarter, row.Format)</td>
                                <td class="py-2 px-2 text-right text-slate-700">@FormatMetric(row.PreviousQuarter, row.Format)</td>
                                <td class="py-2 px-2 text-right @(rowQoqUp ? "text-emerald-600" : "text-red-600")">
                                    @(row.QuarterOverQuarterChangePercent.HasValue ? row.QuarterOverQuarterChangePercent.Value.ToString("+0.0;-0.0") + "%" : "-")
                                </td>
                                <td class="py-2 px-2 text-right text-slate-700">@FormatMetric(row.CurrentYear, row.Format)</td>
                                <td class="py-2 px-2 text-right text-slate-700">@FormatMetric(row.PreviousYear, row.Format)</td>
                                <td class="py-2 pl-2 text-right @(rowYoyUp ? "text-emerald-600" : "text-red-600")">
                                    @(row.YearOverYearChangePercent.HasValue ? row.YearOverYearChangePercent.Value.ToString("+0.0;-0.0") + "%" : "-")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Doanh thu theo quý</h3>
                <canvas id="quarterlyRevenueChart" height="160"></canvas>
            </article>

            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Doanh thu theo năm</h3>
                <canvas id="yearlyRevenueChart" height="160"></canvas>
            </article>
        </section>
    }

    @if (showOperations)
    {
        <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Đăng ký mới 7 ngày & phân bố gói</h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                    <div>
                        <p class="text-sm text-slate-500 mb-2">Đăng ký mới</p>
                        <canvas id="newSubsChart" height="160"></canvas>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 mb-2">Gói đang hoạt động</p>
                        <canvas id="planDistChart" height="160"></canvas>
                    </div>
                </div>
            </article>

            <article class="dash-card rounded-2xl p-5">
                <h3 class="text-base font-bold text-slate-900 mb-4">Thanh toán thất bại gần đây</h3>
                @if (d.RecentFailedPayments.Any())
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="text-left border-b border-slate-200 text-slate-500 uppercase text-xs">
                                    <th class="py-2 pr-2">Payment</th>
                                    <th class="py-2 px-2">Khách hàng</th>
                                    <th class="py-2 px-2 text-right">Số tiền</th>
                                    <th class="py-2 px-2">Phương thức</th>
                                    <th class="py-2 pl-2">Thời gian</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pay in d.RecentFailedPayments)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                                        <td class="py-3 pr-2 text-slate-500">#@pay.PaymentId</td>
                                        <td class="py-3 px-2 text-slate-700">@pay.CustomerName</td>
                                        <td class="py-3 px-2 text-right text-red-600 font-semibold">@pay.Amount.ToString("N0") VND</td>
                                        <td class="py-3 px-2 text-slate-500">@pay.Method</td>
                                        <td class="py-3 pl-2 text-slate-500">@pay.CreatedAt.ToString("dd/MM HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-sm text-slate-500">Không có thanh toán thất bại gần đây.</p>
                }
            </article>
        </section>
    }
</div>

@section Scripts {
    <script>
        const muted = '#64748b';
        const grid = 'rgba(148,163,184,.25)';

        function el(id) { return document.getElementById(id); }

        if (el('revenueChart')) {
            const selectedDays = @d.SelectedDays;
            const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.RevenueLastThirtyDays.Select(x => x.Label)));
            const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.RevenueLastThirtyDays.Select(x => x.Amount)));

            new Chart(el('revenueChart'), {
                type: 'line',
                data: {
                    labels: revenueLabels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: revenueData,
                        borderColor: '#0f766e',
                        backgroundColor: 'rgba(20,184,166,.15)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: selectedDays >= 90 ? 0 : 2,
                        pointHoverRadius: 4,
                        pointHitRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            ticks: {
                                color: muted,
                                autoSkip: true,
                                maxTicksLimit: selectedDays >= 90 ? 10 : 12,
                                maxRotation: 0,
                                minRotation: 0
                            },
                            grid: { color: grid }
                        },
                        y: { ticks: { color: muted }, grid: { color: grid } }
                    }
                }
            });
        }

        if (el('orderStatusChart')) {
            new Chart(el('orderStatusChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.OrderStatusDistribution.Select(x => x.Status))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.OrderStatusDistribution.Select(x => x.Count))),
                        backgroundColor: ['#0ea5e9', '#14b8a6', '#f59e0b', '#ef4444', '#6366f1', '#334155'],
                        borderRadius: 8,
                        maxBarThickness: 36
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: muted }, grid: { display: false } },
                        y: { ticks: { color: muted, stepSize: 1 }, grid: { color: grid }, beginAtZero: true }
                    }
                }
            });
        }

        if (el('newSubsChart')) {
            new Chart(el('newSubsChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.NewSubscriptionsLast7Days.Select(x => x.Label))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.NewSubscriptionsLast7Days.Select(x => x.Count))),
                        borderRadius: 7,
                        maxBarThickness: 28,
                        backgroundColor: 'rgba(29,78,216,.78)'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: muted }, grid: { display: false } },
                        y: { ticks: { color: muted, stepSize: 1 }, grid: { color: grid }, beginAtZero: true }
                    }
                }
            });
        }

        if (el('planDistChart')) {
            new Chart(el('planDistChart'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.SubscriptionPlanDistribution.Select(x => x.PlanName))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.SubscriptionPlanDistribution.Select(x => x.Count))),
                        backgroundColor: ['#0f766e', '#0ea5e9', '#f59e0b', '#ef4444', '#475569'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '58%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: muted, padding: 14, boxWidth: 12 }
                        }
                    }
                }
            });
        }

        if (el('quarterlyRevenueChart')) {
            new Chart(el('quarterlyRevenueChart'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.QuarterlyRevenueCurrentYear.Select(x => x.QuarterLabel))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.QuarterlyRevenueCurrentYear.Select(x => x.Revenue))),
                        borderRadius: 8,
                        maxBarThickness: 42,
                        backgroundColor: 'rgba(15,118,110,.78)'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: muted }, grid: { display: false } },
                        y: { ticks: { color: muted }, grid: { color: grid }, beginAtZero: true }
                    }
                }
            });
        }

        if (el('yearlyRevenueChart')) {
            new Chart(el('yearlyRevenueChart'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.YearlyRevenueLastFiveYears.Select(x => x.Year))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(d.YearlyRevenueLastFiveYears.Select(x => x.Revenue))),
                        borderColor: '#1d4ed8',
                        backgroundColor: 'rgba(59,130,246,.14)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: muted }, grid: { color: grid } },
                        y: { ticks: { color: muted }, grid: { color: grid }, beginAtZero: true }
                    }
                }
            });
        }

        function formatCurrency(v) {
            return `${new Intl.NumberFormat('vi-VN').format(v)} VND`;
        }

        function formatSignedCurrency(v) {
            const abs = new Intl.NumberFormat('vi-VN').format(Math.abs(v));
            if (v > 0) return `+${abs} VND`;
            if (v < 0) return `-${abs} VND`;
            return `0 VND`;
        }

        function formatPercent(v) {
            if (v === null || v === undefined) return 'N/A';
            return `${v >= 0 ? '+' : ''}${Number(v).toFixed(1)}%`;
        }

        function applyTrendClass(amountElement, percentElement, value) {
            const amountClass = value >= 0 ? 'font-bold text-emerald-600' : 'font-bold text-red-600';
            const percentClass = value >= 0 ? 'text-xs text-emerald-600' : 'text-xs text-red-600';
            amountElement.className = amountClass;
            percentElement.className = percentClass;
        }

        function syncAllCompareInputs(data) {
            const map = {
                q1y: data.selectedQuarter1Year,
                q1: data.selectedQuarter1,
                q2y: data.selectedQuarter2Year,
                q2: data.selectedQuarter2,
                y1: data.selectedYear1,
                y2: data.selectedYear2
            };

            Object.entries(map).forEach(([name, value]) => {
                document.querySelectorAll(`select[name="${name}"], input[name="${name}"]`).forEach(control => {
                    control.value = String(value);
                });
            });
        }

        async function submitComparisonForm(form, button) {
            const params = new URLSearchParams(new FormData(form));
            params.set('handler', 'RevenueComparison');
            const url = `${window.location.pathname}?${params.toString()}`;

            const oldText = button.textContent;
            button.disabled = true;
            button.textContent = 'Đang tải...';

            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (!response.ok) {
                    throw new Error('Không thể tải dữ liệu so sánh.');
                }

                const data = await response.json();
                syncAllCompareInputs(data);

                const quarterSummary = el('quarterCompareSummary');
                if (quarterSummary) {
                    quarterSummary.innerHTML = `A: <span class="font-semibold">Q${data.selectedQuarter1}/${data.selectedQuarter1Year}</span> | B: <span class="font-semibold">Q${data.selectedQuarter2}/${data.selectedQuarter2Year}</span>`;
                }

                const quarterA = el('quarterRevenueA');
                const quarterB = el('quarterRevenueB');
                const quarterDiffAmount = el('quarterDiffAmount');
                const quarterDiffPercent = el('quarterDiffPercent');
                if (quarterA && quarterB && quarterDiffAmount && quarterDiffPercent) {
                    quarterA.textContent = formatCurrency(data.selectedQuarter1Revenue);
                    quarterB.textContent = formatCurrency(data.selectedQuarter2Revenue);
                    quarterDiffAmount.textContent = formatSignedCurrency(data.selectedQuarterRevenueDiffAmount);
                    quarterDiffPercent.textContent = formatPercent(data.selectedQuarterRevenueDiffPercent);
                    applyTrendClass(quarterDiffAmount, quarterDiffPercent, data.selectedQuarterRevenueDiffAmount);
                }

                const yearSummary = el('yearCompareSummary');
                if (yearSummary) {
                    yearSummary.innerHTML = `A: <span class="font-semibold">${data.selectedYear1}</span> | B: <span class="font-semibold">${data.selectedYear2}</span>`;
                }

                const yearA = el('yearRevenueA');
                const yearB = el('yearRevenueB');
                const yearDiffAmount = el('yearDiffAmount');
                const yearDiffPercent = el('yearDiffPercent');
                if (yearA && yearB && yearDiffAmount && yearDiffPercent) {
                    yearA.textContent = formatCurrency(data.selectedYear1Revenue);
                    yearB.textContent = formatCurrency(data.selectedYear2Revenue);
                    yearDiffAmount.textContent = formatSignedCurrency(data.selectedYearRevenueDiffAmount);
                    yearDiffPercent.textContent = formatPercent(data.selectedYearRevenueDiffPercent);
                    applyTrendClass(yearDiffAmount, yearDiffPercent, data.selectedYearRevenueDiffAmount);
                }
            } catch (err) {
                console.error(err);
                alert('Không tải được dữ liệu so sánh. Vui lòng thử lại.');
            } finally {
                button.disabled = false;
                button.textContent = oldText;
            }
        }

        document.querySelectorAll('form[data-compare-form]').forEach(form => {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const button = form.querySelector('button[type="submit"]');
                if (!button) return;
                await submitComparisonForm(form, button);
            });
        });
    </script>
}

