@using System.Security.Claims
@{
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "Admin";
    var initials = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "A";
    var currentPath = Context.Request.Path.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter','system-ui','sans-serif'] } } }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <style>
        body { font-family: 'Inter', system-ui, sans-serif; background: #f1f5f9; color: #1e293b; }

        /* ── Card / Glass → white card ── */
        .glass {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        /* ── Sidebar ── */
        .sidebar { background: #ffffff; border-right: 1px solid #e2e8f0; }
        .sidebar-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 14px; border-radius: 10px;
            font-size: 14px; font-weight: 500; color: #64748b;
            transition: all 0.15s;
        }
        .sidebar-link:hover { color: #059669; background: #f0fdf4; }
        .sidebar-link.active { color: #059669; background: #ecfdf5; font-weight: 600; }
        .sidebar-link.active i { color: #059669; }

        /* ── Override dark Tailwind utility classes ── */
        .text-white { color: #1e293b !important; }
        .text-gray-300 { color: #475569 !important; }
        .text-gray-400 { color: #64748b !important; }
        .text-gray-500 { color: #94a3b8 !important; }
        .text-gray-600 { color: #64748b !important; }

        .text-emerald-400 { color: #059669 !important; }
        .text-red-400 { color: #dc2626 !important; }
        .text-blue-400 { color: #2563eb !important; }
        .text-yellow-400 { color: #d97706 !important; }
        .text-amber-400 { color: #d97706 !important; }
        .text-orange-400 { color: #ea580c !important; }
        .text-purple-400 { color: #7c3aed !important; }
        .text-pink-400 { color: #db2777 !important; }

        [class*="bg-white/"] { background-color: #f8fafc !important; }
        [class*="border-white/"] { border-color: #e2e8f0 !important; }
        .bg-\[#0a0a0f\] { background: #f1f5f9 !important; }

        .bg-emerald-500\/10, .bg-emerald-500\/20 { background-color: #ecfdf5 !important; }
        .bg-red-500\/10, .bg-red-500\/20 { background-color: #fef2f2 !important; }
        .bg-blue-500\/10, .bg-blue-500\/20 { background-color: #eff6ff !important; }
        .bg-yellow-500\/10 { background-color: #fffbeb !important; }
        .bg-amber-500\/10 { background-color: #fffbeb !important; }
        .bg-orange-500\/10 { background-color: #fff7ed !important; }
        .bg-purple-500\/10 { background-color: #f5f3ff !important; }
        .bg-gray-500\/10 { background-color: #f8fafc !important; }

        .border-emerald-500\/20, .border-emerald-500\/15, .border-emerald-500\/30,
        .border-emerald-500\/40 { border-color: #a7f3d0 !important; }
        .border-red-500\/20, .border-red-500\/30 { border-color: #fecaca !important; }
        .border-blue-500\/15, .border-blue-500\/20 { border-color: #bfdbfe !important; }

        .hover\:bg-white\/5:hover, .hover\:bg-white\/10:hover,
        .hover\:bg-white\/15:hover, .hover\:bg-white\/20:hover { background-color: #f1f5f9 !important; }

        .bg-clip-text.text-transparent { -webkit-text-fill-color: #1e293b; }

        /* Table overrides */
        table { color: #374151; }
        thead tr { background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
        tbody tr { border-bottom: 1px solid #f1f5f9; }
        tbody tr:hover { background: #f8fafc; }

        /* Modal overlay stays dark */
        .fixed.inset-0.bg-black\/60 { background: rgba(0,0,0,0.5) !important; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-slate-100 text-gray-900 min-h-screen flex">

    <!-- SIDEBAR -->
    <aside class="sidebar hidden lg:flex flex-col w-64 fixed inset-y-0 left-0 z-40">
        <!-- Logo -->
        <div class="flex items-center gap-2 px-6 py-5 border-b border-gray-100">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center">
                <i class="bi bi-shield-lock-fill text-white text-sm"></i>
            </div>
            <span class="text-base font-bold text-gray-900">Admin Panel</span>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
            <div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider px-3 mb-2">Tổng Quan</div>
            <a href="/Admin" class="sidebar-link @(currentPath == "/Admin" || currentPath == "/Admin/" ? "active" : "")">
                <i class="bi bi-grid-1x2 text-base w-5"></i> Dashboard
            </a>

            <div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider px-3 mt-5 mb-2">Quản Lý</div>
            <a href="/Admin/Users" class="sidebar-link @(currentPath.Contains("/Admin/Users") ? "active" : "")">
                <i class="bi bi-people text-base w-5"></i> Người Dùng
            </a>
            <a href="/Admin/Meals" class="sidebar-link @(currentPath.Contains("/Admin/Meals") ? "active" : "")">
                <i class="bi bi-cup-hot text-base w-5"></i> Món Ăn
            </a>
            <a href="/Admin/Plans" class="sidebar-link @(currentPath.Contains("/Admin/Plans") ? "active" : "")">
                <i class="bi bi-layers text-base w-5"></i> Gói Dịch Vụ
            </a>
            <a href="/Admin/Subscriptions" class="sidebar-link @(currentPath.Contains("/Admin/Subscriptions") ? "active" : "")">
                <i class="bi bi-journal-check text-base w-5"></i> Đăng Ký
            </a>

            <div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider px-3 mt-5 mb-2">Vận Hành</div>
            <a href="/Admin/DeliveryOrders" class="sidebar-link @(currentPath.Contains("/Admin/DeliveryOrders") ? "active" : "")">
                <i class="bi bi-truck text-base w-5"></i> Đơn Giao Hàng
            </a>
            <a href="/Admin/DeliveryProcessing" class="sidebar-link @(currentPath.Contains("/Admin/DeliveryProcessing") ? "active" : "")">
                <i class="bi bi-gear text-base w-5"></i> Xử Lý Giao Hàng
            </a>
            <a href="/Admin/KitchenExport" class="sidebar-link @(currentPath.Contains("/Admin/KitchenExport") ? "active" : "")">
                <i class="bi bi-clipboard-data text-base w-5"></i> Kitchen Export
            </a>
            <a href="/Admin/FeedbackReport" class="sidebar-link @(currentPath.Contains("/Admin/FeedbackReport") ? "active" : "")">
                <i class="bi bi-bar-chart text-base w-5"></i> Báo Cáo Đánh Giá
            </a>
            <a href="/Admin/Support" class="sidebar-link @(currentPath.Contains("/Admin/Support") ? "active" : "")">
                <i class="bi bi-headset text-base w-5"></i> Hỗ Trợ
            </a>
        </nav>

        <!-- User info -->
        <div class="px-4 py-4 border-t border-gray-100">
            <div class="flex items-center gap-3 px-2">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-sm font-bold text-white">
                    @initials
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 truncate">@fullName</p>
                    <p class="text-xs text-gray-400">Administrator</p>
                </div>
                <a href="/Auth/Logout" class="text-gray-400 hover:text-red-500 transition" title="Đăng Xuất">
                    <i class="bi bi-box-arrow-right text-lg"></i>
                </a>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="flex-1 lg:ml-64 min-h-screen flex flex-col">
        <!-- Mobile top bar -->
        <header class="lg:hidden sticky top-0 z-30 bg-white border-b border-gray-200 shadow-sm px-4 py-3 flex items-center justify-between">
            <button onclick="document.getElementById('mobileSidebar').classList.toggle('hidden')" class="text-gray-500 hover:text-emerald-600">
                <i class="bi bi-list text-xl"></i>
            </button>
            <span class="font-bold text-sm text-gray-900">Admin Panel</span>
            <a href="/Auth/Logout" class="text-gray-400 hover:text-red-500"><i class="bi bi-box-arrow-right"></i></a>
        </header>

        <!-- Mobile sidebar overlay -->
        <div id="mobileSidebar" class="hidden fixed inset-0 z-50 lg:hidden">
            <div class="absolute inset-0 bg-black/50" onclick="document.getElementById('mobileSidebar').classList.add('hidden')"></div>
            <div class="absolute left-0 top-0 bottom-0 w-64 bg-white border-r border-gray-200 shadow-xl p-4 space-y-1">
                <a href="/Admin" class="sidebar-link"><i class="bi bi-grid-1x2 w-5"></i> Dashboard</a>
                <a href="/Admin/Users" class="sidebar-link"><i class="bi bi-people w-5"></i> Người Dùng</a>
                <a href="/Admin/Meals" class="sidebar-link"><i class="bi bi-cup-hot w-5"></i> Món Ăn</a>
                <a href="/Admin/Plans" class="sidebar-link"><i class="bi bi-layers w-5"></i> Gói Dịch Vụ</a>
                <a href="/Admin/Subscriptions" class="sidebar-link"><i class="bi bi-journal-check w-5"></i> Đăng Ký</a>
                <a href="/Admin/DeliveryOrders" class="sidebar-link"><i class="bi bi-truck w-5"></i> Đơn Giao Hàng</a>
                <a href="/Admin/DeliveryProcessing" class="sidebar-link"><i class="bi bi-gear w-5"></i> Xử Lý</a>
                <a href="/Admin/KitchenExport" class="sidebar-link"><i class="bi bi-clipboard-data w-5"></i> Kitchen Export</a>
                <a href="/Admin/FeedbackReport" class="sidebar-link"><i class="bi bi-bar-chart w-5"></i> Báo Cáo ĐG</a>
                <a href="/Admin/Support" class="sidebar-link"><i class="bi bi-headset w-5"></i> Hỗ Trợ</a>
            </div>
        </div>

        <!-- Page Content -->
        <main class="flex-1 p-6 lg:p-8 max-w-[1400px] w-full mx-auto">
            @RenderBody()
        </main>
    </div>

    <div id="toastContainer" class="fixed top-4 right-4 z-[9999] flex flex-col gap-2"></div>

    <script>
        function showToast(msg, type = 'success') {
            const c = document.getElementById('toastContainer');
            const t = document.createElement('div');
            const isOk = type === 'success';
            t.className = `bg-white border shadow-lg px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2 ${isOk ? 'text-emerald-700 border-emerald-200' : 'text-red-600 border-red-200'}`;
            t.innerHTML = `<i class="bi ${isOk ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill'}"></i> ${msg}`;
            c.appendChild(t);
            setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
        }

        const ORDER_STATUS_MAP = {
            'Planned': { label: 'Đã lên kế hoạch', badge: 'bg-gray-100 text-gray-600' },
            'Preparing': { label: 'Đang chuẩn bị', badge: 'bg-amber-100 text-amber-700' },
            'Delivering': { label: 'Đang giao', badge: 'bg-blue-100 text-blue-700' },
            'Delivered': { label: 'Đã giao', badge: 'bg-emerald-100 text-emerald-700' },
            'ConfirmedByUser': { label: 'Đã xác nhận nhận hàng', badge: 'bg-purple-100 text-purple-700' },
            'Cancelled': { label: 'Đã hủy', badge: 'bg-red-100 text-red-600' },
            'InProgress': { label: 'Đang xử lý', badge: 'bg-yellow-100 text-yellow-700' },
            'Completed': { label: 'Hoàn thành', badge: 'bg-blue-100 text-blue-700' },
            'Disputed': { label: 'Tranh chấp', badge: 'bg-orange-100 text-orange-700' }
        };
        function updateOrderStatusDom(orderId, newStatus) {
            const row = document.querySelector(`tr[data-order-id="${orderId}"]`);
            if (!row) return;
            const badge = row.querySelector('.order-status-badge');
            if (!badge) return;
            const map = ORDER_STATUS_MAP[newStatus] || { label: newStatus, badge: 'bg-gray-100 text-gray-600' };
            badge.textContent = map.label;
            const base = badge.className.includes('inline-flex') ? 'order-status-badge inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold ' : 'order-status-badge px-2 py-1 rounded-lg text-xs font-medium ';
            badge.className = base + map.badge;
        }

        const dashConn = new signalR.HubConnectionBuilder().withUrl('/hubs/dashboard').withAutomaticReconnect().build();
        const orderConn = new signalR.HubConnectionBuilder().withUrl('/hubs/order').withAutomaticReconnect().build();
        const trackConn = new signalR.HubConnectionBuilder().withUrl('/hubs/order-tracking').withAutomaticReconnect().build();
        window.adminTrackConn = trackConn;
        dashConn.on('ReceiveDashboardUpdate', () => { showToast('Dashboard đã cập nhật!'); setTimeout(() => location.reload(), 1500); });
        orderConn.on('SubscriptionChanged', (subId, status) => {
            if (window.location.pathname.includes('/Admin/Subscriptions')) {
                showToast('Đăng ký #' + subId + ' đã thay đổi');
                setTimeout(() => location.reload(), 800);
            }
        });
        orderConn.on('ReceiveOrderStatusUpdate', (orderId, newStatus) => {
            if (typeof orderId === 'number') {
                updateOrderStatusDom(orderId, newStatus);
                showToast('Đơn #' + orderId + ' đã cập nhật trạng thái');
            }
        });
        trackConn.on('OrderItemStatusChanged', (orderItemId, orderId, status, proofUrl) => { showToast('Món #' + orderItemId + ' đã giao'); });
        trackConn.on('OrderStatusChanged', (orderId, status, source) => {
            if (typeof orderId === 'number') { updateOrderStatusDom(orderId, status); showToast('Đơn #' + orderId + ' đã hoàn thành'); }
        });
        trackConn.on('MealRated', (data) => {
            if (data && data.mealId) {
                const row = document.querySelector(`.meal-avg-row[data-meal-id="${data.mealId}"]`);
                if (row) {
                    row.style.display = '';
                    const val = row.querySelector('.meal-avg-value');
                    if (val) val.textContent = (data.newAvgRating ?? 0).toFixed(1);
                }
                if (typeof showToast === 'function') showToast('⭐ Đánh giá mới: ' + (data.ratedBy || 'Khách') + ' - ' + data.stars + ' sao');
            }
        });
        const joinAdminGroups = () => Promise.all([
            dashConn.invoke('JoinAdminDashboard'),
            orderConn.invoke('JoinAdminGroup'),
            trackConn.invoke('JoinAdminGroup')
        ]);
        Promise.all([dashConn.start(), orderConn.start(), trackConn.start()])
            .then(joinAdminGroups)
            .catch(err => console.warn('SignalR:', err));
        dashConn.onreconnected(joinAdminGroups);
        orderConn.onreconnected(joinAdminGroups);
        trackConn.onreconnected(joinAdminGroups);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
