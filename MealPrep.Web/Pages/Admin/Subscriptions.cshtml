@page
@model MealPrep.Web.Pages.Admin.SubscriptionsModel
@using BusinessObjects.Enums
@using MealPrep.BLL.Services
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Đăng Ký";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">📋 Quản Lý Đăng Ký</h1>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-4 py-3 rounded-xl mb-4 text-sm">
        <i class="bi bi-check-circle me-1"></i> @Model.SuccessMessage
    </div>
}

<!-- Filters -->
<form method="get" class="glass rounded-2xl p-4 mb-6">
    <div class="flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs text-gray-500 mb-1">Tìm email</label>
            <input type="text" name="Search" value="@Model.Search" placeholder="Email khách hàng..."
                   class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-xl text-white text-sm focus:border-emerald-500 focus:outline-none" />
        </div>
        <div>
            <label class="block text-xs text-gray-500 mb-1">Trạng thái</label>
            <select name="StatusFilter" class="px-3 py-2 bg-white/5 border border-white/10 rounded-xl text-white text-sm focus:border-emerald-500 focus:outline-none">
                <option value="">Tất cả</option>
                @foreach (var s in Model.AllStatuses)
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <button type="submit" class="px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-sm transition">
            <i class="bi bi-search me-1"></i> Lọc
        </button>
    </div>
</form>

<!-- Subscriptions Table -->
<div class="glass rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-gray-500 text-xs uppercase border-b border-white/10">
                    <th class="text-left py-3 px-4">ID</th>
                    <th class="text-left py-3 px-4">Khách hàng</th>
                    <th class="text-left py-3 px-4">Gói</th>
                    <th class="text-left py-3 px-4">Thời hạn</th>
                    <th class="text-right py-3 px-4">Tổng tiền</th>
                    <th class="text-center py-3 px-4">Đơn hàng</th>
                    <th class="text-center py-3 px-4">Trạng thái</th>
                    <th class="text-right py-3 px-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in Model.Result.Items)
                {
                    var statusBadge = sub.Status switch {
                        SubscriptionStatus.Active => "bg-emerald-500/10 text-emerald-400",
                        SubscriptionStatus.PendingPayment => "bg-yellow-500/10 text-yellow-400",
                        SubscriptionStatus.Cancelled => "bg-red-500/10 text-red-400",
                        SubscriptionStatus.Expired => "bg-gray-500/10 text-gray-400",
                        _ => "bg-gray-500/10 text-gray-400"
                    };

                    <tr class="border-b border-white/5 hover:bg-white/[0.02]">
                        <td class="py-3 px-4 text-gray-400">#@sub.Id</td>
                        <td class="py-3 px-4">
                            <p class="font-medium">@sub.CustomerName</p>
                            <p class="text-xs text-gray-500">@sub.CustomerEmail</p>
                        </td>
                        <td class="py-3 px-4">
                            <span class="text-emerald-400">@sub.PlanName</span>
                            <span class="text-xs text-gray-500 ml-1">(@sub.MealsPerDay bữa/ngày)</span>
                        </td>
                        <td class="py-3 px-4 text-xs text-gray-400">
                            @sub.StartDate.ToString("dd/MM/yyyy")
                            @if (sub.EndDate.HasValue)
                            {
                                <span>→ @sub.EndDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                        <td class="py-3 px-4 text-right font-medium">@sub.TotalAmount.ToString("N0")₫</td>
                        <td class="py-3 px-4 text-center">@sub.OrderCount</td>
                        <td class="py-3 px-4 text-center">
                            <span class="px-2 py-1 rounded-lg text-xs font-medium @statusBadge">@sub.Status</span>
                        </td>
                        <td class="py-3 px-4">
                            <form method="post" asp-page-handler="OverrideStatus" class="flex items-center gap-1 justify-end">
                                <input type="hidden" name="subId" value="@sub.Id" />
                                <select name="newStatus" class="px-2 py-1 bg-white/5 border border-white/10 rounded-lg text-xs text-white focus:outline-none">
                                    @foreach (var s in Model.AllStatuses)
                                    {
                                        <option value="@s" selected="@(s == sub.Status)">@s</option>
                                    }
                                </select>
                                <button type="submit" class="px-2 py-1 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 text-xs rounded-lg transition">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Result.TotalPages > 1)
    {
        <div class="flex items-center justify-between p-4 border-t border-white/10">
            <p class="text-xs text-gray-500">Trang @Model.Result.Page / @Model.Result.TotalPages (@Model.Result.TotalCount mục)</p>
            <div class="flex gap-1">
                @for (int i = 1; i <= Model.Result.TotalPages; i++)
                {
                    <a href="?PageIndex=@i&Search=@Model.Search&StatusFilter=@Model.StatusFilter"
                       class="w-8 h-8 flex items-center justify-center text-xs rounded-lg transition
                       @(i == Model.Result.Page ? "bg-emerald-500 text-white" : "bg-white/5 text-gray-400 hover:bg-white/10")">
                        @i
                    </a>
                }
            </div>
        </div>
    }
</div>
