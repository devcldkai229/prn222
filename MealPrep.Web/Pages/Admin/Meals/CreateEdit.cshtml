@page
@model MealPrep.Web.Pages.Admin.Meals.CreateEditModel
@using MealPrep.BLL.Services
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.IsEdit ? "Sửa Món Ăn" : "Thêm Món Ăn";
}

@section Styles {
    <style>
        .btn-voice-recording, .btn-voice-recording i, .btn-voice-recording span { color: #ffffff !important; }
        .btn-submit-meal { color: #ffffff !important; }
    </style>
}

<div class="mb-8">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <div class="flex items-center gap-3">
            <a href="/Admin/Meals" class="w-10 h-10 rounded-xl bg-white border border-slate-200 hover:bg-slate-50 flex items-center justify-center text-slate-600 hover:text-slate-900 transition shadow-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">@(Model.IsEdit ? "Sửa Món Ăn" : "Thêm Món Ăn")</h1>
                <p class="text-sm text-slate-500 mt-0.5">@(Model.IsEdit ? "Cập nhật thông tin món ăn" : "Thêm món mới vào danh sách")</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <span id="voiceStatus" class="text-sm text-slate-500 hidden"></span>
            <button type="button" id="btnVoiceInput" class="btn-voice-recording px-5 py-2.5 rounded-xl bg-violet-600 hover:bg-violet-700 text-sm font-semibold flex items-center gap-2 transition shadow-md shadow-violet-600/25">
                <i class="bi bi-mic-fill text-base"></i>
                <span id="btnVoiceText">Ghi âm mô tả món ăn</span>
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-xl mb-4 text-sm">
        <i class="bi bi-exclamation-circle me-1"></i> @Model.ErrorMessage
    </div>
}

<form method="post" enctype="multipart/form-data" class="max-w-3xl">
    <input type="hidden" asp-for="MealId" />

    <div class="glass rounded-2xl p-6 mb-6 space-y-6">
        <!-- Thông tin cơ bản -->
        <div>
            <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i class="bi bi-info-circle text-emerald-600"></i> Thông tin cơ bản
            </h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Tên món ăn <span class="text-red-500">*</span></label>
                    <input asp-for="Dto.Name" type="text" required placeholder="VD: Cơm gà xé"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
                    <span asp-validation-for="Dto.Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Mô tả</label>
                    <textarea asp-for="Dto.Description" rows="3" placeholder="Mô tả ngắn về món ăn..."
                              class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none resize-none transition"></textarea>
                </div>
            </div>
        </div>

        <!-- Dinh dưỡng -->
        <div>
            <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i class="bi bi-bar-chart text-emerald-600"></i> Thông tin dinh dưỡng
            </h2>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Calories <span class="text-red-500">*</span></label>
                    <input asp-for="Dto.Calories" type="number" required placeholder="0"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Protein (g) <span class="text-red-500">*</span></label>
                    <input asp-for="Dto.Protein" type="number" step="0.1" required placeholder="0"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Carbs (g) <span class="text-red-500">*</span></label>
                    <input asp-for="Dto.Carbs" type="number" step="0.1" required placeholder="0"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Fat (g) <span class="text-red-500">*</span></label>
                    <input asp-for="Dto.Fat" type="number" step="0.1" required placeholder="0"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
                </div>
            </div>
        </div>

        <!-- Nguyên liệu -->
        <div>
            <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i class="bi bi-list-ul text-emerald-600"></i> Nguyên liệu
            </h2>
            <input asp-for="Dto.IngredientsRaw" type="text" placeholder="Gà, Rau xanh, Cơm, Gia vị... (cách nhau bởi dấu phẩy)"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 placeholder-slate-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 focus:outline-none transition" />
        </div>

        <!-- Trạng thái & Hình ảnh -->
        <div>
            <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wide mb-4 flex items-center gap-2">
                <i class="bi bi-image text-emerald-600"></i> Hình ảnh & Trạng thái
            </h2>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <input asp-for="Dto.IsActive" type="checkbox" class="w-5 h-5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                    <label class="text-sm font-medium text-slate-700">Món đang hoạt động (hiển thị cho khách)</label>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Thêm hình ảnh món ăn</label>
                    <input type="file" name="Images" multiple accept="image/*"
                           onchange="previewImages(this)"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-slate-800 file:bg-emerald-600 file:text-white file:border-0 file:rounded-lg file:px-4 file:py-2 file:mr-4 file:text-sm file:font-medium" />
                    <div id="imagePreview" class="flex gap-2 mt-3 flex-wrap"></div>
                </div>
            </div>
        </div>

        @if (Model.IsEdit && Model.ExistingMeal?.Images?.Length > 0)
        {
            <div>
                <label class="block text-xs text-gray-500 mb-1">Hình ảnh hiện tại</label>
                <div class="flex gap-2 flex-wrap">
                    @foreach (var img in Model.ExistingMeal.Images)
                    {
                        <img src="@img" alt="Current" class="w-20 h-20 rounded-xl object-cover border border-slate-200 shadow-sm" />
                    }
                </div>
            </div>
        }
    </div>

    <div class="flex gap-3">
        <button type="submit" class="btn-submit-meal px-6 py-3 bg-emerald-600 hover:bg-emerald-700 rounded-xl font-semibold transition shadow-md shadow-emerald-600/25 flex items-center gap-2">
            <i class="bi bi-check-lg"></i> @(Model.IsEdit ? "Cập nhật món" : "Tạo món ăn")
        </button>
        <a href="/Admin/Meals" class="px-6 py-3 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl font-medium text-slate-700 transition">Hủy</a>
    </div>
</form>

@section Scripts {
    @Html.AntiForgeryToken()
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            const btn = document.getElementById('btnVoiceInput');
            const btnText = document.getElementById('btnVoiceText');
            const statusEl = document.getElementById('voiceStatus');
            let mediaRecorder = null;
            let audioChunks = [];
            let isRecording = false;

            function setBtnState(recording, analyzing) {
                btn.classList.add('btn-voice-recording');
                if (analyzing) {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-white/40 border-t-white rounded-full animate-spin"></span> <span>Đang phân tích...</span>';
                } else if (recording) {
                    btn.disabled = false;
                    btn.classList.add('ring-2', 'ring-red-400', 'animate-pulse');
                    btn.innerHTML = '<i class="bi bi-stop-fill"></i> <span>Dừng ghi âm</span>';
                } else {
                    btn.disabled = false;
                    btn.classList.remove('ring-2', 'ring-red-400', 'animate-pulse');
                    btn.innerHTML = '<i class="bi bi-mic-fill text-base"></i> <span>Ghi âm mô tả món ăn</span>';
                }
            }

            function showStatus(msg, visible) {
                statusEl.textContent = msg;
                statusEl.classList.toggle('hidden', !visible);
            }

            async function sendAudioAndFillForm(blob) {
                showStatus('', false);
                setBtnState(false, true);
                try {
                    const fd = new FormData();
                    fd.append('audioFile', blob, 'recording.webm');
                    fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');

                    const res = await fetch('?handler=AnalyzeVoice', { method: 'POST', body: fd });
                    const data = await res.json();

                    if (data.success) {
                        if (data.name) document.querySelector('input[name="Dto.Name"]').value = data.name;
                        if (data.description) document.querySelector('textarea[name="Dto.Description"]').value = data.description || '';
                        if (data.calories != null) document.querySelector('input[name="Dto.Calories"]').value = data.calories;
                        if (data.protein != null) document.querySelector('input[name="Dto.Protein"]').value = data.protein;
                        if (data.carbs != null) document.querySelector('input[name="Dto.Carbs"]').value = data.carbs;
                        if (data.fat != null) document.querySelector('input[name="Dto.Fat"]').value = data.fat;
                        if (data.ingredientsRaw != null) document.querySelector('input[name="Dto.IngredientsRaw"]').value = data.ingredientsRaw || '';
                        alert('Đã điền thông tin từ giọng nói. Kiểm tra và chỉnh sửa nếu cần.');
                    } else {
                        alert('Lỗi: ' + (data.error || 'Không xác định'));
                    }
                } catch (e) {
                    alert('Lỗi kết nối: ' + e.message);
                } finally {
                    setBtnState(false, false);
                }
            }

            async function startRecording() {
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    audioChunks = [];
                    mediaRecorder = new MediaRecorder(stream);

                    mediaRecorder.ondataavailable = e => { if (e.data.size > 0) audioChunks.push(e.data); };
                    mediaRecorder.onstop = async () => {
                        stream.getTracks().forEach(t => t.stop());
                        if (audioChunks.length > 0) {
                            const blob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
                            await sendAudioAndFillForm(blob);
                        } else {
                            alert('Không có dữ liệu ghi âm. Vui lòng thử lại.');
                        }
                    };

                    mediaRecorder.start();
                    isRecording = true;
                    setBtnState(true, false);
                    showStatus('Đang ghi âm...', true);
                } catch (e) {
                    alert('Không thể truy cập microphone. Vui lòng cấp quyền ghi âm cho trình duyệt.');
                    console.error(e);
                }
            }

            function stopRecording() {
                if (mediaRecorder && isRecording && mediaRecorder.state !== 'inactive') {
                    mediaRecorder.stop();
                    isRecording = false;
                    showStatus('Đang xử lý...', true);
                }
            }

            btn.addEventListener('click', function() {
                if (btn.disabled) return;
                if (isRecording) {
                    stopRecording();
                } else {
                    startRecording();
                }
            });
        })();

        function previewImages(input) {
            const container = document.getElementById('imagePreview');
            container.innerHTML = '';
            Array.from(input.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'w-20 h-20 rounded-xl object-cover border border-slate-200 shadow-sm';
                    container.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}
